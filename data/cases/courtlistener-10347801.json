  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Jones arrived at the emergency room of HMH the evening of September 18, 2017, complaining of stomach pain.",
      "paragraph_ref": "47",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Aurora evaluated Mr. Jones and diagnosed him with an inguinal hernia and incarcerated bowel.",
      "paragraph_ref": "49",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Aurora performed Mr. Jones\u2019s abdominal surgery on the evening of September 19 with no complications.",
      "paragraph_ref": "66",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Jones\u2019s near-syncopal episode and the subsequent deterioration of his condition on the afternoon of September 20 were likely caused by a small pulmonary embolism.",
      "paragraph_ref": "82",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Appellees offered testimony that Dr. Kennedy breached the standard of care by failing to include pulmonary embolism in his differential diagnosis of Mr. Jones.",
      "paragraph_ref": "5",
      "speaker": "Plaintiff's expert"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "HMH offered competing expert testimony purporting to show that the treatment decisions made by Dr. Kennedy were within the standard of care.",
      "paragraph_ref": "5",
      "speaker": "Defense expert"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The trial court denied that motion, and HMH filed this timely appeal.",
      "paragraph_ref": "41",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "JUDGMENT OF THE CIRCUIT COURT FOR HARFORD COUNTY AFFIRMED; COSTS TO BE PAID BY APPELLANT.",
      "paragraph_ref": "687",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "We see no abuse of discretion in the evidentiary rulings and conduct that HMH here challenges.",
      "paragraph_ref": "672",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Jones died suddenly of a pulmonary embolism, which occurs when a blood clot from elsewhere in the body migrates through the blood stream and lodges in a blood vessel in the lung.",
      "paragraph_ref": "29",
      "speaker": "Court finding"
    }
  ],
