  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On the morning of October 13, 2015, Carroll Reid underwent an upper endoscopy",
      "paragraph_ref": "25",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Reid fell to the ground and injured his back. He died two weeks later from complications related to emergency spinal surgery.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "The plaintiffs offered expert testimony from a board-certified anesthesiologist, who opined that the gastroenterologist violated the standard of care in the post-procedure discharge assessment of the patient.",
      "paragraph_ref": "4",
      "speaker": "Expert witness"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The erroneous grant of summary judgment in favor of one defendant did not provide a basis to overturn the verdicts in favor of the other defendants.",
      "paragraph_ref": "8",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Reid’s surviving family members brought a medical negligence and wrongful death action in the Circuit Court for Baltimore County against health care providers",
      "paragraph_ref": "29",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Khan recommended that Mr. Reid undergo an upper endoscopy with biopsies and dilation.",
      "paragraph_ref": "48",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "MEDICAL_RECORD",
      "text": "Mr. Reid signed a consent form in which he agreed that CRNA Sergott would administer anesthesia during the procedure under the supervision of Dr. Khan.",
      "paragraph_ref": "70",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "CRNA Sergott used an intravenous line to administer two short-acting sedative drugs, Propofol and Versed, to Mr. Reid.",
      "paragraph_ref": "81",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Khan approved Mr. Reid for discharge at 7:28 a.m.",
      "paragraph_ref": "94",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Reid walked out of the BACE facility, accompanied by Ms. Reid.",
      "paragraph_ref": "96",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E011",
      "type": "FACTUAL_FINDING",
      "text": "X-ray images of Mr. Reid’s lumbar spine showed no visible fractures.",
      "paragraph_ref": "105",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E012",
      "type": "FACTUAL_FINDING",
      "text": "The MRI images showed an unstable fracture in two thoracic vertebrae.",
      "paragraph_ref": "114",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E013",
      "type": "LEGAL_FINDING",
      "text": "JUDGMENT OF THE CIRCUIT COURT FOR BALTIMORE COUNTY AFFIRMED IN PART AND REVERSED IN PART.",
      "paragraph_ref": "1622",
      "speaker": "Judge's conclusion"
    }
  ],
