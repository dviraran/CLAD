  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Giorgio Webster brought an action in the Macomb Circuit Court against Dr. Jeffrey Osguthorpe and Summit Oral and Maxillofacial Surgery, PC, for dental malpractice concerning care rendered during a biopsy.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On December 8, 2020, the parties participated in what was then mandatory case evaluation under MCR 2.403.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "The case-evaluation panel entered an evaluation that included an award in favor of plaintiff; plaintiff accepted the award, but defendants rejected it.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Following a trial, the jury returned a verdict in favor of plaintiff.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "The trial court held a hearing and granted plaintiff\u2019s request for sanctions, applying the former court rule.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The Court of Appeals held that even if the trial court had discretion to apply former MCR 2.403(O), a sanctions award was not justified because the verdict that plaintiff received was so substantially above the case-evaluation award that there was no injustice to plaintiff.",
      "paragraph_ref": "6",
      "speaker": "Court of Appeals"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We reverse the Court of Appeals\u2019 judgment in part and reinstate the trial court\u2019s award of case-evaluation sanctions.",
      "paragraph_ref": "24",
      "speaker": "Supreme Court"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "The jury returned a verdict in favor of plaintiff, awarding $68,000 in past economic damages, $1.375 million in past noneconomic damages, and $1.307 million in future noneconomic damages.",
      "paragraph_ref": "38",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The trial court did not abuse its discretion by awarding case-evaluation sanctions to plaintiff under former MCR 2.403(O).",
      "paragraph_ref": "307",
      "speaker": "Supreme Court"
    }
  ],
