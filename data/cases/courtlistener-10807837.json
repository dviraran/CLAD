  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Supak Beard was diagnosed with lupus in 1991. Lupus is an incurable, chronic autoimmune disease where a person\u2019s immune system attacks their own tissues and organs.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Mrs. Beard established care with Dr. Shaila Gala, a rheumatologist, in 2007. Dr. Gala managed Mrs. Beard\u2019s lupus by prescribing various medications, including prednisone.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "On February 5, 2015, Mrs. Beard went to the walk-in clinic, reporting feeling unwell and experiencing chills for 6 days.",
      "paragraph_ref": "40",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "On March 22, Mrs. Beard had a follow-up appointment with Dr. Gala. She had a high fever and worsening symptoms.",
      "paragraph_ref": "71",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Mrs. Beard immediately underwent surgery. On March 24, Mrs. Beard passed away while recovering from surgery.",
      "paragraph_ref": "77",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The jury determined that Dr. Gala did not breach the standard of care and returned a defense verdict.",
      "paragraph_ref": "99",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The trial court acted within its discretion in giving the exercise of judgment instruction.",
      "paragraph_ref": "437",
      "speaker": "Judge's analysis"
    }
  ],
