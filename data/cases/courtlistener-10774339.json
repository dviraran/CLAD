  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Walgreens Co. (\u201cWalgreens\u201d) appeals a final judgment resulting from a jury verdict in favor of Maria Victoria Chaux (\u201cChaux\u201d) and the denial of its motion for a new trial.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "After a five-day trial, the jury returned a verdict in Chaux\u2019s favor and awarded damages of $5,547,733.",
      "paragraph_ref": "25",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "While in the checkout lane of her neighborhood Walgreens, Chaux fell on her back and unconscious.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "As a result of the fall, Chaux suffered a brain injury and was in the hospital for over three months.",
      "paragraph_ref": "23",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The trial court erred in imposing a burden-shifting spoliation sanction without proper notice.",
      "paragraph_ref": "276",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We conclude that together, these errors denied Walgreens a fair trial, and therefore the trial court abused its discretion in denying Walgreens\u2019 motion for a new trial.",
      "paragraph_ref": "282",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "This error was compounded by the trial court\u2019s improper exclusion of Walgreens\u2019 expert, Dr. Goldstein, under Daubert.",
      "paragraph_ref": "281",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Goldstein ultimately concluded that Chaux \u201cwas having likely [an alcohol] withdrawal seizure.",
      "paragraph_ref": "101",
      "speaker": "Dr. Goldstein"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Chaux alleged that Walgreens knew or should have known of the dangerous condition, failed to timely maintain the floor, and failed to warn of the dangerous condition.",
      "paragraph_ref": "50",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "Reversed and remanded for a new trial.",
      "paragraph_ref": "287",
      "speaker": "Judge's conclusion"
    }
  ],
