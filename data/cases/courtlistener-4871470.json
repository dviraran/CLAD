  "summary": {
    "brief": "Crim v. Dietrich. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In August 2015, plaintiffs, Kristopher Crim and Teri Crim, acting on behalf of their biological son, Collin Crim (born June 17, 2005), filed a fourth amended medical malpractice claim against defendant, Gina Dietrich, D.O.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Defendant failed to obtain Teri\u2019s informed consent to perform a natural birth despite possible risks associated with Collin\u2019s large size.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "During Collin\u2019s June 17, 2005, natural delivery, Collin suffered shoulder dystocia, which is an obstructed labor whereby, after the delivery of the head, one or both shoulders of an infant cannot pass or requires significant manipulation.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "As a result, Collin suffered a broken clavicle and extensive nerve damage in his right shoulder, arm, and hand.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The appellate court issued its opinion in Crim I, reversing the circuit\u2019s court\u2019s judgment and remanding the case to the circuit court.",
      "paragraph_ref": "11",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We answer the certified question in the negative, and we reverse the judgment of the appellate court.",
      "paragraph_ref": "43",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The majority\u2019s assertion that a proper use of Rule 308 is to determine the effects that previous decisions have on the pending case contradicts this court\u2019s prior case law on Rule 308.",
      "paragraph_ref": "76",
      "speaker": "Dissenting opinion"
    }
  ],
