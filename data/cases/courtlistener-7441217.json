  "summary": {
    "brief": "Handy v. Box Hill Surgery Ctr.. Medical malpractice case involving neurology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Bhambhani placed her first order of MPA from NECC in January of 2009.",
      "paragraph_ref": "42",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On June 29, 2012, NECC manufactured lot #06292012 of MPA. At some point in its manufacturing, lot #06292012 was contaminated with fungi.",
      "paragraph_ref": "46",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Bhambhani administered the injection on August 31, 2012, using MPA from her August 13 NECC order which included vials from lot #06292012.",
      "paragraph_ref": "53",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Rozek developed a headache followed by symptoms such as 'nausea, vomiting, weakness on her right side, double vision, and problems with balance.'",
      "paragraph_ref": "56",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Rozek\u2019s autopsy report revealed that she died from fungal meningitis.",
      "paragraph_ref": "59",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Plaintiffs argued constituted a breach of the standard of care because, in their view, drugs from compounding pharmacies are inherently riskier.",
      "paragraph_ref": "63",
      "speaker": "Plaintiffs' expert"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The jury returned a verdict that found that Dr. Bhambhani breached the standard of care in the treatment of Rozek and that Dr. Bhambhani\u2019s breach caused the illness and death of Rozek.",
      "paragraph_ref": "94",
      "speaker": "Jury finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "However, the jury also found that NECC\u2019s negligence was an intervening and superseding cause of Rozek\u2019s illness and death. Dr. Bhambhani was thus found not liable.",
      "paragraph_ref": "96",
      "speaker": "Jury finding"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "We hold that there was a triable issue generated because a jury could reasonably conclude that NECC\u2019s conduct was unforeseeable and a superseding cause.",
      "paragraph_ref": "350",
      "speaker": "Court reasoning"
    }
  ],
