  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Deanna Trevarthen died on 5 December 2016 aged 45. Her death was caused by mesothelioma, which is a fatal cancer caused by exposure to asbestos.",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Ms Trevarthen contended her mesothelioma arose from contact with her father when she was a young girl. Her father worked as an electrician, an occupation which at that time had high exposure to asbestos.",
      "paragraph_ref": "2",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr Reid replied as follows: As greater than 94% of mesothelioma patients report a known exposure to asbestos... it is highly likely that this case was caused by asbestos exposure.",
      "paragraph_ref": "126",
      "speaker": "Dr Reid"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The appeal is allowed. The District Court\u2019s decision is set aside.",
      "paragraph_ref": "139",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "I have found that inhaling the fibres was an \u201caccident\u201d under the 2001 Act.",
      "paragraph_ref": "136",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "In the middle of 2015 Ms Trevarthen began to feel unwell. She had a persistent cough, chest pain, shortness of breath, night sweats, a loss of appetite and weight loss over a few months.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr Sullivan and Ms Fraser both commented in their reports that Ms Trevarthen would not be eligible for ACC funding because she did not have work-related exposure to asbestos.",
      "paragraph_ref": "15",
      "speaker": "Dr Sullivan and Ms Fraser"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "Ms Trevarthen was entitled to cover under the Accident Compensation Act 2001 for mesothelioma because this was a personal injury caused by an accident to her.",
      "paragraph_ref": "140",
      "speaker": "Judge's conclusion"
    }
  ],
