    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "If negligence or malpractice is alleged that must be established as behaviour which falls seriously short of that which is to be considered acceptable",
      "paragraph_ref": "64",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The Tribunal finds this particular of the Charge made out as misconduct both as malpractice and as conduct bringing the profession into disrepute.",
      "paragraph_ref": "90",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Dr Zimmerman had been suspended from practice by an order of the DCNZ.",
      "paragraph_ref": "91",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The Tribunal finds particular 5 made out as to all its sub-particulars and that this is misconduct warranting disciplinary sanction.",
      "paragraph_ref": "154",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E010",
      "type": "COURT_REASONING",
