    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On June 7, 2021, Glindale Randolph was admitted to St. Francis Medical Center for surgery on an abscess located on his right thigh.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Randolph, who was 46 years old, had a history of diabetes and hypertension.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Randolph was examined by Dr. Minh Mai, a hospital medicine physician, on June 8.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "A tachycardic heart rate of 114 beats per minute and decreased oxygen saturation were noted.",
      "paragraph_ref": "25",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "On the night of June 9, Randolph had several hours of acute hypoxia with his oxygen levels falling to as low as 50%.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "He was unresponsive and had no pulse or respirations. He was pronounced dead at 11:43 p.m.",
      "paragraph_ref": "43",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "The cause of death was a saddle pulmonary embolism due to deep vein thrombosis.",
      "paragraph_ref": "44",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "we conclude that the trial court did not err in sustaining the exception of no cause of action.",
      "paragraph_ref": "212",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "At Ellis\u2019s cost, the judgment granting the exception of no cause of action is affirmed and the matter is remanded to the trial court for further proceedings.",
      "paragraph_ref": "227",
      "speaker": "Judge's conclusion"
    }
  ],
