  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Peter, who was sixty-one years old, underwent surgery to replace his left knee. The surgery was performed by Michael E. Joyce, an orthopedic surgeon employed by the defendant.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The discharge instructions provided to Peter following the surgery advised him that he had the highest chance of developing deep vein thrombosis (DVT), a type of blood clot, in the days and weeks after surgery.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Beginning on September 23, 2015, Peter began to experience pain and swelling in his calf.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "On October 1, 2015, Peter began to struggle to breathe. He was taken to a hospital, where he died shortly after arrival.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Santore testified that Libby had breached the applicable standard of care by failing to send Peter for an ultrasound of his calf when Peter presented with symptoms consistent with a possible DVT.",
      "paragraph_ref": "19",
      "speaker": "Expert witness"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The jury returned a verdict against the defendant on both counts of the complaint and awarded damages of $5.5 million on the wrongful death count and $3 million on the loss of consortium count.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The court unequivocally rejected the defendant\u2019s argument that the offer of compromise contained conditional language that rendered the offer of compromise facially invalid.",
      "paragraph_ref": "85",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The judgments are affirmed.",
      "paragraph_ref": "93",
      "speaker": "Court conclusion"
    }
  ],
