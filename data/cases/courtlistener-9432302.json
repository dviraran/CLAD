  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Waechter alleged that in December 2017, Brad M. Picha, M.D. (“Dr. Picha”), an orthopedic surgeon for Laser Spine Institute, LLC (“LSI”), evaluated her, and performed a laminotomy with foraminotomy and decompression of the nerve root at C4-C5 on her right side.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Waechter alleged that she reported numbness in her left arm and left leg 15 minutes after the procedure followed by numbness and severe weakness in her left upper and lower extremities and tongue.",
      "paragraph_ref": "31",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Patil further provided the following opinion regarding the presence of air seen in Waechter’s CT: could be caused by an operation on the right.",
      "paragraph_ref": "161",
      "speaker": "Dr. Patil"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The jury returned a verdict in favor of the defense and the case was dismissed with prejudice.",
      "paragraph_ref": "278",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "We find that Waechter’s counsel invited error by opening the door to Dr. Patil’s standard-of-care testimony on cross-examination and that his testimony on direct examination was not contrary to Evid.R. 601(B)(5).",
      "paragraph_ref": "646",
      "speaker": "Judge's analysis"
    }
  ],
