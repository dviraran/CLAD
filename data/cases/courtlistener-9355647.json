  "outcome_severity": "DEATH",
  "summary": {
    "brief": "Richard S. Pergolizzi, Jr., M.D. v. Ramona Bowman. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In October 2017, Ramona Bowman experienced a sudden severe headache localized to the left side of her head.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The CT scan revealed a bleed in the back right part of her brain, known as a 'subarachnoid hemorrhage' ('SAH').",
      "paragraph_ref": "25",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Bowman first visited Dr. Pergolizzi on October 31, 2017, at which time he documented that she was not currently experiencing headaches.",
      "paragraph_ref": "29",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Pergolizzi recommended a vascular test called a 'cerebral angiogram,' which he performed on November 7, 2017.",
      "paragraph_ref": "34",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Bowman signed a form consenting to the surgery.",
      "paragraph_ref": "3",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Bowman\u2019s experts testified that Dr. Pergolizzi was wrong to conclude that Bowman had a ruptured aneurysm.",
      "paragraph_ref": "73",
      "speaker": "Expert testimony"
    },
    {
      "evidence_id": "E007",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Fredieu opined that Dr. Pergolizzi violated the standard of care by not suggesting the possibility of 'just monitoring the aneurysm.'",
      "paragraph_ref": "107",
      "speaker": "Expert testimony"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The jury returned a general verdict for Bowman, awarding her over $3,000,000 in damages.",
      "paragraph_ref": "148",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The trial court reduced the judgment to the statutory medical malpractice cap and entered final judgment in Bowman\u2019s favor.",
      "paragraph_ref": "149",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "COURT_REASONING",
      "text": "The trial court erred in allowing Bowman\u2019s experts to testify that Dr. Pergolizzi\u2019s diagnosis was wrong.",
      "paragraph_ref": "293",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E011",
      "type": "COURT_REASONING",
      "text": "Because we find that a physician has no duty to inform a patient that the physician may have misdiagnosed the patient or offer treatment options that would only make sense for conditions the doctor has excluded, the trial court erred.",
      "paragraph_ref": "604",
      "speaker": "Judge's analysis"
    }
  ],
