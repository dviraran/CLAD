  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "C.G. was born at Banner Health. Late on the second day of her life, C.G. was transferred to the neonatal intensive care unit (NICU), where she received antibiotics to treat a possible infection.",
      "paragraph_ref": "84",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The following morning, lab results confirmed that C.G. had an E. coli infection. By that time, C.G. had developed sepsis.",
      "paragraph_ref": "87",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "As a result of the sepsis, she suffered irreversible neurological injuries, including cerebral palsy and cognitive and developmental delays.",
      "paragraph_ref": "89",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The jury found that Banner Health was negligent and that its negligence was the proximate cause of C.G.\u2019s injuries.",
      "paragraph_ref": "95",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The judgment is affirmed.",
      "paragraph_ref": "1185",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Rimawi testified that he is qualified to offer expert testimony on causation.",
      "paragraph_ref": "534",
      "speaker": "Expert witness"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The court did not abuse its discretion by finding that the Gressers had shown good cause for future economic damages.",
      "paragraph_ref": "323",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "The jury awarded the Gressers damages totaling $27,647,274.23.",
      "paragraph_ref": "97",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "The court entered judgment in their favor in the amount of $39,845,196.83.",
      "paragraph_ref": "62",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "COURT_REASONING",
      "text": "The court properly applied the good cause and unfairness analysis when deciding to lift the cap.",
      "paragraph_ref": "141",
