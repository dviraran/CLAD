  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "I found firstly, that the Claimant had current capacity to litigate and had had capacity to litigate at all material times",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr Kirwilliam, neuropsychologist, provided a report to Ms Trask, solicitor for the Claimant, dated July 2017, in which he concluded that the Claimant had the capacity to conduct proceedings",
      "paragraph_ref": "22",
      "speaker": "Dr Kirwilliam"
    },
    {
      "evidence_id": "E003",
      "type": "LEGAL_FINDING",
      "text": "The Claimant is clearly the successful party. If the preliminary issue had been lost his claim would have come to end.",
      "paragraph_ref": "39",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E004",
      "type": "COURT_REASONING",
      "text": "I reject Mr Roy's submission that the costs should be on the indemnity basis. There was nothing out of the ordinary or unreasonable about the conduct of the Defendant",
      "paragraph_ref": "40",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "I do not accept Ms Christie-Brown's submission that this is a suitable case for an issue based costs order.",
      "paragraph_ref": "41",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The Claimant should receive 70% of his costs of the preliminary issue on the standard basis to be assessed if not agreed.",
      "paragraph_ref": "47",
      "speaker": "Judge's conclusion"
    }
  ],
