  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Geraldine Kittis (\u201cKittis\u201d), individually and as the administrator for the estate of Mr. Dennis Kittis (\u201cMr. Kittis\u201d), appeals the jury verdict in favor of the Cleveland Clinic Foundation (\u201cthe Clinic\u201d) following a trial on wrongful-death and medical-malpractice claims.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Kittis was hospitalized for a bowel obstruction and had a preexisting heart condition. He underwent surgery to remove the obstruction, during which one of the surgeons unintentionally punctured Mr. Kittis\u2019s intestines.",
      "paragraph_ref": "38",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "One day later, Mr. Kittis began experiencing low blood pressure and high lactate levels initially thought to be caused by dehydration, which was treated with IV fluids.",
      "paragraph_ref": "42",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Brooks testified that the three potential etiologies [causes] he would attribute to causing [Mr. Kittis\u2019s] bowel ischemia were torsion, a blood clot, or venous obstruction.",
      "paragraph_ref": "90",
      "speaker": "Dr. Brooks"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The jury\u2019s verdict is affirmed.",
      "paragraph_ref": "365",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "The cause of the bowel ischemia was deemed irrelevant to the question posed on proximate cause, which was the Clinic\u2019s failure to initiate the surgery earlier in the day.",
      "paragraph_ref": "93",
      "speaker": "Court reasoning"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Kittis underwent a laparotomy performed by Dr. Augustin. The laparotomy was an exploratory surgery used to potentially identify the root cause of Mr. Kittis\u2019s declining condition.",
      "paragraph_ref": "54",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Brooks\u2019s expert testimony was sufficient to establish that the Clinic\u2019s failure to recognize in a timely fashion the progressive acidosis and renal dysfunction was the proximate cause of [Mr. Kittis\u2019s] injuries and death.",
      "paragraph_ref": "84",
      "speaker": "Dr. Brooks"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "The CT scan was cancelled by Dr. Julia Muntean, who was under the authority of Dr. Toms Augustin, Mr. Kittis\u2019s treating physician.",
      "paragraph_ref": "47",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "The court finds there were reasonable grounds for this appeal.",
      "paragraph_ref": "367",
      "speaker": "Judge's conclusion"
    }
  ],
