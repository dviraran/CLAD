  "case_name": "Younas v Okeahialam [2019] EWHC 2502 (QB) (26 September 2019)",
  "neutral_citation": "[2019] EWHC 2502",
  "clinical_domain": "CARDIOLOGY",
  "outcome_severity": "PERMANENT_SEVERE_DISABILITY",
  "summary": {
    "brief": "Medical malpractice case involving cardiology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Mr Younas had been to his local GP practice in the previous June and September, with symptoms which the doctors did not connect with a possible heart condition.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "He went again on 18 th October 2013, complaining of unusual breathlessness after exertion and what felt to him like an unusual heartbeat (palpitations), amongst other things.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "The ECG measures the electrical activity of the heart by placing sensor pads on the skin for a short while.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "He took the ECG test at the surgery on 21 st October 2013, three days after his GP appointment.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "When the results came back to Dr Okeahialam that day, they showed some electrical abnormalities.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "The doctor now accepts that he should have referred Mr Younas to a hospital cardiology department for further investigation, as soon as the ECG result came back.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Mr Tahir Younas was walking across a car park on 24 th January 2014 when he suddenly lost consciousness and fell to the ground.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "His faint was caused by an undiagnosed heart condition. It was eventually diagnosed as 'intermittent atrioventricular (AV) block'.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "The condition is treatable with a pacemaker, and he later had one fitted.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "That negligence is admitted. The issue before me is causation.",
      "paragraph_ref": "16",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E011",
      "type": "EXPERT_TESTIMONY",
      "text": "The expert cardiologists agree that in these circumstances it is more probable than not that he had the condition at least from that time onwards.",
      "paragraph_ref": "40",
      "speaker": "Expert cardiologists"
    },
    {
      "evidence_id": "E012",
      "type": "LEGAL_FINDING",
      "text": "I am persuaded on this analysis that it is more likely than not that treatment for insertion of Mr Younas's pacemaker would have begun before the 24 th January 2014.",
      "paragraph_ref": "76",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E013",
      "type": "COURT_REASONING",
      "text": "I am entirely persuaded by Prof Myerson's careful evidence that, in clinical practice, the diagnosis of intermittent AV block can be difficult and elusive.",
      "paragraph_ref": "90",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E014",
      "type": "LEGAL_FINDING",
      "text": "For the reasons given above, my conclusion is that the negligence of Dr Okeahialam, in failing to refer an abnormal ECG result to a hospital cardiology department, caused Mr Younas to collapse on 24 th January 2014 because of undiagnosed and untreated intermittent AV block, and to sustain serious injury as a direct result.",
      "paragraph_ref": "103",
      "speaker": "Judge's conclusion"
    }
  ],
