  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "The plaintiff, Jennifer Bradley, brings this civil action against the defendant, the United States of America, asserting common law claims of negligent infliction of emotional distress and medical malpractice resulting from the medical treatment provided to her by Dr. Aaron Williams.",
      "paragraph_ref": "3",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On September 23, 2011, during a field hockey game in Richmond, Virginia, the plaintiff was struck in the head by an opposing player’s shoulder.",
      "paragraph_ref": "47",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Despite these symptoms, the plaintiff continued to practice and play in games with the field hockey team from September 25, 2011, through October 2, 2011.",
      "paragraph_ref": "55",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "WITNESS_STATEMENT",
      "text": "The plaintiff testified that she told Jennings and Earls that she “c[ould]n’t think, and it[ wa]s scaring [her], and [she] c[ould]n’t see correctly.”",
      "paragraph_ref": "67",
      "speaker": "Plaintiff"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Cantu further testified that the standard of care requires that, when treating an athlete with a suspected concussion, the athlete should be removed from play.",
      "paragraph_ref": "607",
      "speaker": "Dr. Cantu"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "For the reasons set forth above, the Court finds in favor of the plaintiff on her medical malpractice claim against the defendant, in the amount of $1,745,194.65.",
      "paragraph_ref": "1545",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The Court assigns more weight to Dr. Cantu’s testimony than it does to Dr. Margo’s testimony, in light of her lack of experience regarding the standard of care for diagnosing and treating a concussion.",
      "paragraph_ref": "10",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "The plaintiff was an undergraduate student in the District of Columbia at American University, where she played varsity field hockey.",
      "paragraph_ref": "35",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The Court concludes that there is no evidence that American University consented to Dr. Williams acting as its agent.",
      "paragraph_ref": "15",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "The plaintiff began to experience issues with her vision, including that her “eyes were not tracking correctly,” and felt “that [she] could[ ]n[o]t really think.”",
      "paragraph_ref": "52",
      "speaker": "Court finding"
    }
  ],
