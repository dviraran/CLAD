  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Patel’s medical negligence was a proximate cause of an injury to Mr. Jones",
      "paragraph_ref": "9",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "LEGAL_FINDING",
      "text": "We conclude that the evidence is legally and factually sufficient to prove that at least one of the multiple standard-of-care breaches alleged by Mr. Jones caused his injury.",
      "paragraph_ref": "19",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E003",
      "type": "LEGAL_FINDING",
      "text": "We reverse the part of the judgment imposing liability on Bianco, and we render judgment that the Joneses take nothing from Bianco.",
      "paragraph_ref": "24",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Jones now suffers weakness in his lower extremities that leaves him largely confined to a wheelchair.",
      "paragraph_ref": "78",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "An injury happened at a segmental -- at a level in the spinal cord that completely explains his postoperative neurological examination and the timing of the events.",
      "paragraph_ref": "141",
      "speaker": "Plaintiff's Expert"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Plaintiff’s Expert opined that an anterolisthesis caused the injury.",
      "paragraph_ref": "627",
      "speaker": "Plaintiff's Expert"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "The neuromonitoring process for this surgery was being observed by both a technician in the operating room and a neurophysiologist who monitored from a location outside the operating room.",
      "paragraph_ref": "67",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "We affirm the judgment as to Dr. Patel, but we reverse the trial court’s judgment that Bianco is jointly and severally liable for the Joneses’ damages.",
      "paragraph_ref": "1669",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Jones presented evidence that his future medical care will cost millions of dollars.",
      "paragraph_ref": "89",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "EXPERT_TESTIMONY",
      "text": "Plaintiff’s Expert concluded that because Dr. Patel did not accept what the neuromonitoring signal had revealed a real finding of a neurological loss.",
      "paragraph_ref": "885",
      "speaker": "Plaintiff's Expert"
    }
