  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Gannett was admitted to the Massachusetts bar in 1982, and practiced law for nearly 40 years before being disbarred on November 3, 2020.",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Gannett represented North Beacon 155 Associates LLC ('North Beacon') in a civil action to recover unpaid rent from a commercial tenant.",
      "paragraph_ref": "11",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "On May 30, 2018, the arbitrator (Neel, J. [ret.]) issued a final decision, awarding $91,699.54 to Gannett on his fee lien claim, but $93,751.90 to North Beacon on its various counterclaims.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Gannett alleges that Attorney Neumeier and Morrison Mahoney negligently represented him in the North Beacon arbitration by, inter alia, failing to prepare and present proper evidence.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "On March 23, 2018, the BBO filed a petition for discipline against Gannett arising from his representation of Amaral Enterprises, LLC ('Amaral') and Bearbones, Inc. ('Bearbones').",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "The BBO held its disciplinary hearings on February 13 and 14, 2019, at which hearings Attorney Greenberg represented Gannett.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "For all the foregoing reasons, Defendants' Motion to Enforce Settlement is ALLOWED.",
      "paragraph_ref": "87",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "Plaintiff did not lack capacity to enter into the settlement agreement, and was not denied reasonable accommodation for his belatedly claimed disability.",
      "paragraph_ref": "87",
      "speaker": "Judge's analysis"
    }
  ],
