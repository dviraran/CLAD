  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Villarreal alleged that Gonzalez, a patient at Edinburg Nursing Rehabilitation Center, Inc., 'suffered severe bedsores that had gone untreated and went septic resulting in her death on December 20, 2019.'",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Regency was not served with Villarreal\u2019s lawsuit until February 1, 2023.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Regency filed its motion to dismiss on August 7, 2023; the trial court held its hearing on the motion to dismiss on September 19, 2023; and the trial court orally granted relator\u2019s motion to dismiss that same day.",
      "paragraph_ref": "161",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "We conclude that the trial court abused its discretion by failing to issue a written ruling on Regency\u2019s motion to dismiss within a reasonable period, and Regency lacks an adequate remedy by appeal to address this error.",
      "paragraph_ref": "274",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "The expert report requirement is to weed out frivolous malpractice claims in the early stages of the trial court\u2019s ruling on a motion to dismiss under the TMLA.",
      "paragraph_ref": "177",
      "speaker": "Court reasoning"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Villarreal did not provide Regency nor the trial court with a copy of the alleged expert report.",
      "paragraph_ref": "62",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We conditionally grant the petition for writ of mandamus. We direct the trial court to promptly rule on Regency\u2019s motion to dismiss.",
      "paragraph_ref": "283",
      "speaker": "Judge's conclusion"
    }
  ],
