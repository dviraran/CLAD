  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Kelley argued that defendants\u2019 medical malpractice caused Kelley to lose vision in her right eye.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Kelley had a 30-year history of headaches, that the number of headache days she experienced monthly increased from one to three and then from three to five.",
      "paragraph_ref": "41",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Contractor ordered a magnetic resonance imaging (\u201cMRI\u201d) scan of Kelley\u2019s brain without intravenous (\u201cIV\u201d) fluid contrast.",
      "paragraph_ref": "48",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Kelley\u2019s vision in her right eye abruptly worsened, resulting in near total vision loss.",
      "paragraph_ref": "69",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Horton argued that the tumor was only detectable with the benefit of hindsight, and that many of the abnormalities that would indicate the presence of a tumor were too subtle.",
      "paragraph_ref": "83",
      "speaker": "Dr. Horton"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Volpe, a neuro-opthamologist, who testified that detection of the tumor in 2019-2020 would not have prevented Kelley from losing her vision in 2021.",
      "paragraph_ref": "93",
      "speaker": "Dr. Volpe"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The judgment of the trial court is affirmed.",
      "paragraph_ref": "261",
      "speaker": "Judge's conclusion"
    }
  ],
