  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On January 24, 2024, Fauvel and Cohen filed a complaint alleging an August 6, 2022 incident.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "As Fauvel was chewing and swallowing her sushi, she 'felt a sharp pain that caused her to reach into her mouth and pull out several one-inch-long bones.'",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Fauvel went to the emergency room. At the emergency room, Fauvel underwent chest and neck x-rays and was taken to the intensive care unit.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "The complaint alleged that Fauvel was released from the hospital on August 7, 2022 \u2014 her wedding day \u2014 around 1 p.m.",
      "paragraph_ref": "31",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The trial court erred as a matter of law by granting judgment on the pleadings.",
      "paragraph_ref": "55",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "The court's judgment on the pleadings in this case was restricted solely to the complaint and answer.",
      "paragraph_ref": "106",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "Judgment reversed, and case remanded for proceedings consistent with this opinion.",
      "paragraph_ref": "150",
      "speaker": "Judge's conclusion"
    }
  ],
