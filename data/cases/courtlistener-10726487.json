  "summary": {
    "brief": "CAROLE ANNE ADAMS v. PIEDMONT HENRY HOSPITAL, INC.. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Ms. Conyers allegedly died from a pulmonary embolism following an appendectomy performed by Dr. Fitzsimmons at Piedmont Henry.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The trial court granted summary judgment to Piedmont Henry, concluding that the plaintiffs failed to present sufficient evidence of causation as to the nurses.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Quinones further opined that the standard of care required Dr. Fitzsimmons to order Heparin.",
      "paragraph_ref": "10",
      "speaker": "Dr. Quinones"
    },
    {
      "evidence_id": "E004",
      "type": "MEDICAL_RECORD",
      "text": "Dr. Fitzsimmons testified that he performed a pre-operative 'VTE' (venous thromboembolism) or 'DVT' (deep vein thrombosis) risk assessment of Ms. Conyers using the Caprini Scale.",
      "paragraph_ref": "39",
      "speaker": "Dr. Fitzsimmons"
    },
    {
      "evidence_id": "E005",
      "type": "WITNESS_STATEMENT",
      "text": "According to Ms. Conyers\u2019 daughter, however, while she was staying with her mother in the hospital on September 27, 28, and 29, her mother complained that 'her legs [were] hurting her. . . her calves and her feet.'",
      "paragraph_ref": "75",
      "speaker": "Ms. Conyers' daughter"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The appeals court affirmed the trial court, ruling that while Dr. Freeman may be qualified to offer expert epidemiological opinion testimony, his epidemiological testimony is not relevant to the issue of causation in this medical malpractice case.",
      "paragraph_ref": "598",
      "speaker": "Appeals court"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The trial court did not consider arguments specific to Piedmont Henry.",
      "paragraph_ref": "6",
      "speaker": "Court reasoning"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Hayes also is providing causation testimony, specifically that Ms. Conyers died of a fatal 'pulmonary embolus,' but Dr. Fitzsimmons has not sought to exclude that portion of Dr. Hayes\u2019 opinion.",
      "paragraph_ref": "7",
      "speaker": "Dr. Hayes"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "On the morning of October 2, 2014, Ms. Conyers developed acute respiratory distress and medical staff had difficulty intubating her.",
      "paragraph_ref": "80",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "Judgment affirmed in part, reversed in part, and vacated in part, and case remanded with direction.",
      "paragraph_ref": "604",
      "speaker": "Court conclusion"
    }
  ],
