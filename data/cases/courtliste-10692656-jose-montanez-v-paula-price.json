  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On August 28, 2021, Jose Montanez stood up in his cell at SCI-Huntingdon and suddenly collapsed, his body numb from the chest down.",
      "paragraph_ref": "23",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Montanez was then left alone in his cell in this condition\u2014paralyzed from his chest to his feet and uncontrollably urinating on himself\u2014for another three days before receiving medical attention.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "An x-ray revealed that Montanez had herniated a disc in his back in the fall, but SCI-Rockview\u2019s Healthcare Administrator, Appellee Richard Ellers, 'lied' to his doctor 'about the results of the x-ray' to delay his treatment.",
      "paragraph_ref": "5",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The District Court erred by dismissing Montanez\u2019s Eighth Amendment claim against Dr. Mahli.",
      "paragraph_ref": "61",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "We will therefore (1) reverse the District Court\u2019s dismissal of Montanez\u2019s Eighth Amendment claims against Dr. Mahli, Nurse Wagman, and Administrator Ellers, the Title II and Section 504 claims against the Commonwealth, and the Section 504 claim against Wellpath.",
      "paragraph_ref": "142",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "The District Court nonetheless denied Montanez\u2019s request for leave to amend, concluding that amendment 'would be futile based on the factual and legal defects' in Montanez\u2019s Complaint.",
      "paragraph_ref": "132",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Montanez was transferred to a private rehabilitation facility.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Montanez\u2019s spinal cord stenosis and edema (which caused paralysis requiring surgery), his sudden incontinence, and the herniated disc he suffered after falling at SCI-Rockview easily qualify as serious medical needs.",
      "paragraph_ref": "50",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The District Court correctly determined that Montanez failed to state a claim under \u00a7 1983 against Wellpath.",
      "paragraph_ref": "59",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Montanez was finally given an MRI that revealed spinal cord stenosis and spinal cord edema, requiring expedited back surgery in September 2021.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    }
  ],
