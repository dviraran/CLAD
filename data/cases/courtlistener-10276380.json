  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Joel Pasienza (\u201cJoel\u201d) was a 37-year-old man who suffered from cerebral palsy and was nonverbal and non-ambulatory.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "He died on September 5, 2017, about five hours after being released from St. Anne Hospital, where he had spent 11 days undergoing treatment for a bowel obstruction.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Following an autopsy, the Lucas County Coroner determined that Joel died of sepsis caused by klebsiella pneumoniae.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "The parties retained expert witnesses who provided standard of care and causation opinions.",
      "paragraph_ref": "107",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Plaintiff presented testimony from hospitalist, Mohammad Alhabbal, who opined that Dr. Crayne deviated from the standard of care for a hospitalist because he failed to address bilateral opacities evident in the imaging.",
      "paragraph_ref": "116",
      "speaker": "Plaintiff's expert"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Joel was discharged from St. Anne on the evening of September 5, 2017, and at approximately 6:00 p.m., he returned to Ann Grady Center, the facility where he lived.",
      "paragraph_ref": "91",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The jury rendered a defense verdict. Interrogatories indicate that it found that the doctors did not breach the standard of care in their treatment of Joel.",
      "paragraph_ref": "681",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "We affirm the July 25, 2023 judgment of the Lucas County Court of Common Pleas.",
      "paragraph_ref": "1304",
      "speaker": "Judge's conclusion"
    }
  ],
