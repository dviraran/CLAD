  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Everett Robinson was transferred to Canton Harbor Healthcare Center, Inc. d/b/a FutureCare-Canton Harbor (“Canton Harbor”), for inpatient follow-up care.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "During his stay at Canton Harbor, Mr. Robinson developed pressure ulcers, also known as decubitus ulcers or, in more common parlance, bedsores.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Nurse Jones-Singh attested that Canton Harbor “breached the standard of care and the breach was the proximate cause of … the development of [Mr. Robinson’s] pressure ulcers.”",
      "paragraph_ref": "34",
      "speaker": "Nurse Jones-Singh"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The circuit court granted Canton Harbor’s motion to dismiss the Complaint on the ground that, as a registered nurse, Nurse Jones-Singh is not qualified to attest to the proximate cause of Mr. Robinson’s pressure ulcers.",
      "paragraph_ref": "40",
      "speaker": "Circuit court"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "The Appellate Court vacated the order of dismissal and remanded the case to the circuit court for further proceedings.",
      "paragraph_ref": "47",
      "speaker": "Appellate Court"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We affirm the judgment of the Appellate Court.",
      "paragraph_ref": "49",
      "speaker": "Supreme Court"
    },
    {
      "evidence_id": "E007",
      "type": "EXPERT_TESTIMONY",
      "text": "According to Nurse Jones-Singh, an SDTI is damage to underlying skin “only caused by friction and/or shearing.",
      "paragraph_ref": "202",
      "speaker": "Nurse Jones-Singh"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "Mrs. Robinson’s negligence claim may go forward.",
      "paragraph_ref": "413",
      "speaker": "Supreme Court"
    }
  ],
