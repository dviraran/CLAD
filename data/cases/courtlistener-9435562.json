  "summary": {
    "brief": "Roland F. Chalifoux, Jr., D.O., individually and Roland F. Chalifoux, Jr., D.O., PLLC d/b/a Valley Pain Management Clinic v. West Virginia Department of Health and Human Resources, West Virginia Bureau of Public Health, Letitia Tierney, M.D., J.D., individually and in her former capacity as West Virginia Commissioner and State Health Officer, West Virginia Board of Osteopathic Medicine, and Diana Shepard, individually and in her capacity as Executive Director for the West Virginia Board of Osteo",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On October 22, 2013, a patient underwent an epidural steroid injection at Chalifoux\u2019s clinic, Valley Pain Management; later that evening she was diagnosed with bacterial meningitis and a report was made to the Bureau.",
      "paragraph_ref": "57",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Laboratory results revealed that the specific flora cultured from the patient\u2019s meningitis was respiratory in nature which, patient\u2019s meningitis was \u201chighly suspicious for iatrogenic [i.e., related to medical treatment] transmission.\u201d",
      "paragraph_ref": "63",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "The Bureau believed that Chalifoux admitted to \u201cdouble-dipping\u201d with syringes, i.e., entering a vial with a used syringe and then later using the vial for a different patient, creating a risk of bloodborne disease transmission.",
      "paragraph_ref": "69",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "In late April 2014, Chalifoux ostensibly began to balk at the scope of the records requests and retained counsel.",
      "paragraph_ref": "96",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The circuit court found that the BOM defendants were entitled to qualified immunity for the summary suspension itself, which was an act within their discretion, but not entitled to immunity for \u201cits failure to perform its non-discretionary duty to hold a hearing within fifteen days of the summary suspension.\u201d",
      "paragraph_ref": "13",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We therefore find no error in the circuit court\u2019s conclusion that Chalifoux could have brought his due process claim in the injunctive action and its grant of summary judgment to the BOM defendants as a result.",
      "paragraph_ref": "503",
      "speaker": "Judge's conclusion"
    }
  ],
