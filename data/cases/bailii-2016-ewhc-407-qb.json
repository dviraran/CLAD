  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "The Claimant in these proceedings, Sido John, is now 44 years old. He graduated in Medicine from Manchester University in 2000 after initially obtaining a degree in Physiology from Leeds University in 1994.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Dr John lost his footing as he was climbing some stairs in the common hallway and fell backwards. Two hours or so later, Dr John was found by a neighbour, another doctor, (then Dr and now Mr) Ben Grey.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr John was admitted to the MRI at about 6.52 am, when he was triaged and seen by a Dr Dafalla Musa, who compiled a management plan which included Dr John undergoing a CT scan on his brain.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "In the event that CT scan was not performed until 1.12 pm, and it is Dr John's case in these proceedings that the delay involved in undertaking that scan was the result of negligence on the part of the Defendant's staff at the MRI.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Dr John underwent a left fronto-parietal craniotomy and evacuation of his acute sub-dural haematoma.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "It is Dr John's case that he suffered an extended period of raised intra-cranial pressure which materially contributed to the cognitive and neuropsychological deficits which he now has.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The Defendant denies liability and takes issue also with causation (as well as with quantum).",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "The parties are agreed that Dr John's residual actual earnings are no more than \u00a35,000 per annum.",
      "paragraph_ref": "266",
      "speaker": "Expert testimony"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "In conclusion, there will be judgment for Dr John against the Defendant in the total sum of \u00a3454,858.65 (inclusive of interest).",
      "paragraph_ref": "283",
      "speaker": "Judge's conclusion"
    }
  ],
