  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Mr White\u2019s primary diagnosis was amblyopia. This is the unilateral or rarely bilateral decrease in best corrected visual acuity",
      "paragraph_ref": "53",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Mr White has admitted that as at 16 December 2010 he had a 16 year old patient with poorish right eye pin hole vision, an abnormal macula",
      "paragraph_ref": "176",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "LEGAL_FINDING",
      "text": "The Tribunal considered that the charge had been established and warranted disciplinary sanction and amounted to professional misconduct",
      "paragraph_ref": "19",
      "speaker": "Tribunal conclusion"
    },
    {
      "evidence_id": "E004",
      "type": "COURT_REASONING",
      "text": "The Tribunal considers that the failure to make a diagnosis of retinal detachment and then not to refer that urgently for an ophthalmologist\u2019s opinion are significant departures",
      "paragraph_ref": "29",
      "speaker": "Tribunal analysis"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Mr White did not refer Mr McGiven to an ophthalmologist until 7 February 2011.",
      "paragraph_ref": "27",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The Tribunal suspends Mr White from practice for a period of six months.",
      "paragraph_ref": "225",
      "speaker": "Tribunal conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Mr White told Mrs McGiven and her son that in view of the abnormality he had detected he wanted to take some more and better photographs.",
      "paragraph_ref": "11",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "Mr Grimmer\u2019s expert opinion",
      "paragraph_ref": "176",
      "speaker": "Expert witness"
    },
    {
      "evidence_id": "E009",
      "type": "WITNESS_STATEMENT",
      "text": "Mr Swanepoel for Mr White did not contest the conclusion that the conduct was professional misconduct",
      "paragraph_ref": "17",
      "speaker": "Mr Swanepoel"
    },
    {
      "evidence_id": "E010",
      "type": "COURT_REASONING",
      "text": "The Tribunal does not impose any fine against Mr White in recognition of the fact that it has suspended him from practice",
      "paragraph_ref": "32",
      "speaker": "Tribunal analysis"
    }
  ],
