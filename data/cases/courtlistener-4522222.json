  "summary": {
    "brief": "Watson v. West Suburban Medical Center. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On December 11, 2008, 24-year-old Denise was 29 weeks into her pregnancy. On that date, she had a regularly scheduled appointment at the PCC Community Wellness Clinic.",
      "paragraph_ref": "5",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Staff directed Denise to go to the WSMC’s obstetrical triage to determine if she was in preterm labor and to monitor the fetal heart rate.",
      "paragraph_ref": "5",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Milik performed a sterile speculum exam to determine if Denise’s amniotic membrane had ruptured.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "At approximately 3 a.m. on December 12, 2008, Denise felt a gush of water down her leg and was taken by ambulance to WSMC.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Denise was seen by nurse Hughes and Dr. Stephen Johnson, a second-year resident.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "On December 26, 2008, Denise’s C-section incision opened. Testing of the incision area was positive for GBS.",
      "paragraph_ref": "9",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "On January 4, 2009, Marques tested positive for GBS and was diagnosed with meningitis, which resulted in significant brain damage.",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The jury found for WSMC and against the plaintiffs, and the trial court entered judgment on the verdict.",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Johnson agreed that had he performed a sterile speculum exam on a 20- to 30-week pregnant patient and found the membrane had ruptured, the standard of care required that the patient be admitted to the hospital and placed on antibiotics.",
      "paragraph_ref": "32",
      "speaker": "Dr. Johnson"
    },
    {
      "evidence_id": "E010",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Diaz explained that if she did not sign the discharge form, it could mean that she did not have any contact with the patient.",
      "paragraph_ref": "37",
      "speaker": "Dr. Diaz"
    },
    {
      "evidence_id": "E011",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Swartz agreed that the lack of the attending’s signature does not mean the attending did not see the patient.",
      "paragraph_ref": "40",
      "speaker": "Dr. Swartz"
    },
    {
      "evidence_id": "E012",
      "type": "WITNESS_STATEMENT",
      "text": "Nurse Hughes explained that the doctors at WSMC routinely communicated with each other.",
      "paragraph_ref": "47",
      "speaker": "Nurse Hughes"
    },
    {
      "evidence_id": "E013",
      "type": "LEGAL_FINDING",
      "text": "The judgment of the trial court is affirmed.",
      "paragraph_ref": "241",
      "speaker": "Court conclusion"
    }
  ],
