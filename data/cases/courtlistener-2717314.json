  "summary": {
    "brief": "Michael L. Mackey v. Steven B. Smith, M.D.. Medical malpractice case involving neurology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On September 17, 2007, DiStefano performed a total hip replacement on Mr. Mackey at St. Francis Hospital in Maryville, Missouri.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "DiStefano placed a prosthetic hip stem into the canal of Mr. Mackey\u201fs femur.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "During the operation, a fluoroscopy-type x-ray was performed, reflecting that the prosthetic stem was placed at a varus (outward) angle in the canal of the femur.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "DiStefano did not take any post-operative x-rays after the surgery although he had been trained to do so.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "On October 1, 2007, Mr. Mackey was evaluated at DiStefano\u201fs office and Mr. Mackey reported at that time that he was doing well with his walker, but that he experienced pain when he attempted to walk with a cane.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "At the hospital, x-rays confirmed that Mr. Mackey had suffered a severely comminuted fracture of his femur.",
      "paragraph_ref": "32",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Smith performed the hip revision surgery on October 3, 2007.",
      "paragraph_ref": "38",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "The culture indicated heavy growth of the bacteria methicillin resistant staphylococcus aureus (MRSA).",
      "paragraph_ref": "50",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Mackey was left on the doxycycline, and prosthetic removal surgery was scheduled for February 27, 2008.",
      "paragraph_ref": "64",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Mackey underwent amputation of his right leg at the hip on August 12, 2008.",
      "paragraph_ref": "71",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E011",
      "type": "LEGAL_FINDING",
      "text": "The jury found in favor of the Mackeys against both DiStefano and Smith, itemizing past and future economic and non-economic damages against DiStefano in the amount of $1,773,500 and against Smith in the amount of $1,684,000.",
      "paragraph_ref": "86",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E012",
      "type": "COURT_REASONING",
      "text": "As long as nine jurors agree to liability and the amount of damages, a different nine jurors may apportion the damages between two defendants.",
      "paragraph_ref": "185",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E013",
      "type": "LEGAL_FINDING",
      "text": "We affirm the judgment of the trial court in all respects.",
      "paragraph_ref": "484",
      "speaker": "Judge's conclusion"
    }
  ],
