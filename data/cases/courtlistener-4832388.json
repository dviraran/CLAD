  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Jill, who was a 42-year old woman, first arrived in the emergency department at Mercy at about 6:45 p.m. on March 16, 2012.",
      "paragraph_ref": "64",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "She complained of abdominal pain, nausea, vomiting, and diarrhea. She had experienced the abdominal pain for the last four days.",
      "paragraph_ref": "66",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "The CMP results showed that Jill\u2019s glucose and liver function were normal. Her blood urea nitrogen, glomerular filtration rate, and creatine, which assess kidney function, were also normal.",
      "paragraph_ref": "81",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Heinrich did not think Jill had toxic shock syndrome that led to bacterial sepsis or shock.",
      "paragraph_ref": "99",
      "speaker": "Dr. Heinrich"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The trial court erred when it refused to give plaintiff\u2019s proposed instruction on informed consent based on IPI Civil (2011) No. 105.07.01.",
      "paragraph_ref": "1048",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We reverse the jury\u2019s verdict finding against plaintiff and in favor of defendants Brett Jones, Scott Heinrich, Amit Arwindekar, Helene Connolly, and Emergency Medicine Physicians of Chicago, and remand for a new trial with respect to these defendants.",
      "paragraph_ref": "1050",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We affirm the jury\u2019s verdict finding in favor of defendant Tara Anderson and Mercy Hospital and Medical Center and against plaintiff.",
      "paragraph_ref": "1053",
      "speaker": "Judge's conclusion"
    }
  ],
