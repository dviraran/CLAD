  "summary": {
    "brief": "Cotton v. Coccaro. Medical malpractice case involving oncology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In 2011, Cotton filed a medical negligence action against several healthcare providers—including Dr. Mitchell, Dr. Cansler, and Dr. Coccaro—in connection with their failure to diagnose her breast cancer.",
      "paragraph_ref": "49",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The case proceeded to a jury trial, and a jury returned a verdict in Cotton’s favor and against Dr. Coccaro and Associated St. James Radiologists in the amount of $6,528,000.",
      "paragraph_ref": "55",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "At age 27, Maya Cotton discovered a pea-sized lump in her breast during a self-examination.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Cotton went to a community health clinic for a breast exam, and a doctor there gave her an order for an ultrasound.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "In March 2009, Cotton went to Dr. Mitchell for the first time and told her about the lump in her breast.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Mitchell performed a breast exam and also felt the lump. After going over Cotton’s medical history and family history, Dr. Mitchell gave Cotton an order for a mammogram and recommended that she go to St. James Hospital in Olympia Fields.",
      "paragraph_ref": "23",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "A radiology technician who performed the mammogram informed Cotton that the mammogram and ultrasound were clear and told her to do a follow-up for regular mammograms after the age of 35.",
      "paragraph_ref": "27",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Gregg Coccaro, a radiologist, had interpreted Cotton’s mammogram and ultrasound.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "The trial court modified the original judgment order to include prejudgment interest, and Cotton withdrew her posttrial motion as moot.",
      "paragraph_ref": "62",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "For all these reasons, we affirm the trial court’s judgment.",
      "paragraph_ref": "628",
      "speaker": "Judge's conclusion"
    }
  ],
