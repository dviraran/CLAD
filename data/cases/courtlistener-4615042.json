  "summary": {
    "brief": "Ned O. Kronfol v. Barbara S. Johnson. Medical malpractice case involving paediatrics.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In 2007, Johnson was diagnosed with kidney failure.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On May 2, 2013, Johnson presented to the emergency room (ER) at Delta Regional Medical Center complaining of lower back pain.",
      "paragraph_ref": "3",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "On May 6, 2013, after receiving dialysis at the Fresenius Clinic, Johnson presented to the emergency room (ER) at Delta Regional Medical Center complaining of severe pain and swelling in her face.",
      "paragraph_ref": "40",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Johnson was treated by Dr. Xander Buenafe, a nephrologist, who diagnosed her with sepsis with tachycardia arising from an infected hemodialysis catheter in her internal jugular (neck).",
      "paragraph_ref": "42",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Gutierrez opined at trial that Dr. Kronfol breached the standard of care in his treatment of Johnson.",
      "paragraph_ref": "217",
      "speaker": "Dr. Gutierrez"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Specifically, Dr. Gutierrez stated that Dr. Kronfol breached the standard of care by allowing Johnson\u2019s temporary catheter to be in for more than one week.",
      "paragraph_ref": "219",
      "speaker": "Dr. Gutierrez"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The jury found that Dr. Kronfol was 100% responsible for Johnson\u2019s injuries.",
      "paragraph_ref": "77",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "We therefore find no abuse of discretion by the trial judge in denying Dr. Kronfol\u2019s motion for a new trial.",
      "paragraph_ref": "1057",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "A jury\u2019s verdict is given great deference by this Court, and conflicts of evidence presented at trial are to be resolved by the jury.",
      "paragraph_ref": "1050",
      "speaker": "Court reasoning"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Johnson received dialysis through a port in her right arm, and later left arm, approximately three times a week at Fresenius Clinic.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    }
  ],
