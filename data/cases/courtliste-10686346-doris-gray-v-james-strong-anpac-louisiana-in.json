  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Gray, age 70, and James Strong (\u201cStrong\u201d), age 77, were both driving north on Broadway Street, a four-lane highway in Delhi.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Strong was passing Gray, she began making a left-hand turn, and the front left corner of her 2015 Chrysler 200 struck the rear passenger door of Strong\u2019s 2020 Ford F-150.",
      "paragraph_ref": "23",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Gray testified that on the day of the accident, she was going from her home to the bank to make a deposit.",
      "paragraph_ref": "81",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Gray said she felt fine for three or four days, but then started experiencing back and neck pain, along with headaches.",
      "paragraph_ref": "96",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Bayonne opined Gray\u2019s injuries were a result of the collision with Strong, diagnosing her with lumbar spondylosis and some disc bulge.",
      "paragraph_ref": "120",
      "speaker": "Dr. Bayonne"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "While Dr. Domangue claimed it was possible Gray was injured as a result of the collision, he never said it was probable.",
      "paragraph_ref": "716",
      "speaker": "Dr. Domangue"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The jury verdict is affirmed. All costs are to be paid by the plaintiff, Doris Gray.",
      "paragraph_ref": "723",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "The jury had significant evidence to conclude Gray was not injured as a result of this minor motor vehicle collision.",
      "paragraph_ref": "717",
      "speaker": "Judge's analysis"
    }
  ],
