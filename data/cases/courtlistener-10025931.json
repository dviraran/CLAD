  "summary": {
    "brief": "Doctor's Weight Loss Ctrs. v. Blackston. Medical malpractice case involving oncology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In September 2018, Ms. Blackston filed a complaint alleging medical malpractice and failure to obtain informed consent in the Circuit Court for Prince George\u2019s County.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The jury awarded Ms. Blackston damages of $2,300,900, which included non-economic damages of $2,000,000, economic damages of $60,000, and medical expenses of $240,900.",
      "paragraph_ref": "32",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "LEGAL_FINDING",
      "text": "The Supreme Court of Maryland held that the Appellate Court of Maryland properly applied Virginia substantive law in accordance with the doctrine of lex loci delicti.",
      "paragraph_ref": "3",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Ramineni opined that Dr. Heron breached the standard of care in several ways, and that those breaches increased the risk that Ms. Blackston would develop an infection.",
      "paragraph_ref": "145",
      "speaker": "Dr. Ramineni"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "During the procedure, she experienced excruciating pain, which Dr. Heron treated with additional injections of the local anesthesia he had administered prior to beginning the procedure.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The jury found that Dr. Heron breached the standard of care in treating Ms. Blackston, that he failed to obtain Ms. Blackston\u2019s informed consent, and that these breaches were a cause of Ms. Blackston\u2019s injuries.",
      "paragraph_ref": "231",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "We hold that the circuit court erred in applying the Maryland cap on non-economic damages to the damages that the jury awarded to Ms. Blackston.",
      "paragraph_ref": "469",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "After the procedure, Ms. Blackston returned to her home in Maryland, where the pain continued. Within a few days, an infection manifested, and she required hospitalization and underwent several procedures to treat that infection.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Ramineni concluded that the procedure caused the infection, citing the number of individual infections.",
      "paragraph_ref": "438",
      "speaker": "Dr. Ramineni"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "JUDGMENT OF THE APPELLATE COURT OF MARYLAND AFFIRMED. PETITIONERS TO PAY COSTS.",
      "paragraph_ref": "480",
      "speaker": "Judge's conclusion"
    }
  ],
