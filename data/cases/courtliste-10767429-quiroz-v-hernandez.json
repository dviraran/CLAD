  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On January 23, 2020, appellant Madelyn Quiroz, then just 16 years old, was a backseat passenger in a car driven by appellee Morgan White.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Morgan was driving at a dangerous speed\u2014around 86 to 96 miles per hour\u2014on a roadway with a posted speed limit of 30 miles per hour.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Madelyn suffered serious injuries from the crash, including a broken back, a serious spinal cord injury, broken ribs, and internal bleeding.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Due to these injuries, Madelyn is now a paraplegic, confined to a wheelchair and paralyzed from the chest down.",
      "paragraph_ref": "12",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The district court characterized Appellants\u2019 claims against the Allegiance Defendants as vague and conclusory.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "We therefore conclude that Appellants also lack standing to file suit against the Liberty County Defendants.",
      "paragraph_ref": "68",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "It is clear that allowing Appellants to replead for the fourth time would be entirely futile.",
      "paragraph_ref": "82",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "For the foregoing reasons, we AFFIRM the district court\u2019s judgment, with the exception of the dismissal of the Liberty County Defendants, whose dismissal we modify to be without prejudice.",
      "paragraph_ref": "82",
      "speaker": "Judge's conclusion"
    }
  ],
