  "summary": {
    "brief": "State of Tennessee v. Gavin Allen Clark. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "The facts giving rise to the instant case stem from the death of the Defendant\u2019s five-week-old son, who suffered from severe brain injury as a result of five separate skull fractures while in the exclusive care, custody, and control of the Defendant.",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The cause of the victim\u2019s death was determined to be blunt force trauma to the victim\u2019s skull associated with child abuse, and the manner of the victim\u2019s death was described as 'beaten by [an] assailant.'",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "WITNESS_STATEMENT",
      "text": "Mother, the victim\u2019s mother and the Defendant\u2019s wife, testified that the victim was born on November 25, 2019, and passed away when he was 'just shy of six weeks old.'",
      "paragraph_ref": "12",
      "speaker": "Mother"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Betters explained that if a child fell from their parents\u2019 arms onto carpeted stairs, if the child was going to have a fracture, she would expect it to happen on that first impact, and then rolling down carpeted stairs, she would not expect subsequent fractures based on impact.",
      "paragraph_ref": "45",
      "speaker": "Dr. Betters"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "Upon review, we conclude that the verdicts returned by the jury in this case were ambiguous because they purport to simultaneously convict and acquit the Defendant.",
      "paragraph_ref": "279",
      "speaker": "Court conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "We also reverse and vacate the Defendant\u2019s convictions because the trial court failed to fulfill its duty as the thirteenth juror.",
      "paragraph_ref": "279",
      "speaker": "Court conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "MEDICAL_RECORD",
      "text": "Before testimony, two exhibits were stipulated to and admitted into evidence: (1) a video showing the victim\u2019s parents entering Walmart to get their taxes done on the morning of the offense; and (2) the victim\u2019s medical records from Vanderbilt University Medical Center ('VUMC') and Tennova Medical Center.",
      "paragraph_ref": "11",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Betters\u2019 diagnosis of the victim was 'inflicted trauma.' Based on her training and medical history, her diagnosis of the victim\u2019s inflicted trauma was child abuse.",
      "paragraph_ref": "55",
      "speaker": "Dr. Betters"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "The Defendant alleged that while holding the victim in his right arm, he tripped on a toy, fell down a set of stairs, and dropped the victim.",
      "paragraph_ref": "10",
      "speaker": "Defendant's statement"
    },
    {
      "evidence_id": "E010",
      "type": "WITNESS_STATEMENT",
      "text": "Mother testified that the Defendant told her that they fell down the stairs 'on the way to come get [her]' from work.",
      "paragraph_ref": "18",
      "speaker": "Mother"
    }
  ],
