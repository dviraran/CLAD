  "summary": {
    "brief": "State v. Grad. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "When W.G. was 41 days old, his parents, Kenneth and Laura Grad, took him to a podiatrist because one of his feet appeared swollen.",
      "paragraph_ref": "5",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "At Akron Children\u2019s Hospital, an x-ray revealed that the tibia in W.G.\u2019s left leg was fractured.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Additional x-rays of W.G.\u2019s body revealed a total of 26 fractures, including fractures of W.G.\u2019s fingers, arms, legs, ribs, and skull.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Steiner testified that on June 18, 2008, he examined W.G. and discussed this examination with the Grads.",
      "paragraph_ref": "21",
      "speaker": "Dr. Steiner"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Steiner concluded that these events were not sufficient to cause the 26 bone fractures seen in W.G.\u2019s x-rays.",
      "paragraph_ref": "21",
      "speaker": "Dr. Steiner"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Steiner testified unequivocally that it could not.",
      "paragraph_ref": "18",
      "speaker": "Dr. Steiner"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We reverse the judgment of the Ninth District Court of Appeals and remand the case to the trial court for it to hold a hearing on Grad\u2019s motion for leave.",
      "paragraph_ref": "83",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "The appellate court erred by affirming the trial court\u2019s denial of Grad\u2019s motion for leave to file a motion for a new trial without holding a hearing on that motion.",
      "paragraph_ref": "82",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E009",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Steiner confirmed that he used a process-of-elimination methodology called differential diagnosis.",
      "paragraph_ref": "26",
      "speaker": "Dr. Steiner"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Doctors sent W.G.\u2019s blood for genetic testing to determine whether he has osteogenesis imperfecta, but the results came back negative.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    }
  ],
