  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "The parents took M to defendants for patient care in November 2004 after he began exhibiting developmental abnormalities.",
      "paragraph_ref": "8",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "In October 2010, the cause of M\u2019s developmental abnormalities was diagnosed as Duchenne muscular dystrophy (DMD).",
      "paragraph_ref": "8",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "The parents and T alleged that defendants negligently failed to perform appropriate diagnostic testing for the symptoms that M was presenting.",
      "paragraph_ref": "9",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The Court of Appeals reversed that judgment as to the parents but affirmed as to T.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "COURT_REASONING",
      "text": "The primary dispute on review is about whether the parents and T had identifiable interests that defendants were legally obligated to protect under the facts alleged in their respective claims.",
      "paragraph_ref": "16",
      "speaker": "Court reasoning"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The decision of the Court of Appeals is affirmed, and the judgment of the circuit court is affirmed in part and reversed in part.",
      "paragraph_ref": "5",
      "speaker": "Court conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "The parents and T each alleged that defendants\u2019 negligence caused them to suffer economic and noneconomic damages.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "The parents allege that their injuries resulted from defendants\u2019 failure to take affirmative steps to protect them.",
      "paragraph_ref": "19",
      "speaker": "Court reasoning"
    }
  ],
