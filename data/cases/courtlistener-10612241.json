  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On January 8, 2015, Dr. Ronald J. French, underwent a laparoscopic partial colectomy performed by Dr. Orangio.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "It is undisputed that Dr. French executed an informed consent form prior to the procedure.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "After the procedure, he suffered a ureteral injury and anastomotic leak.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Dr. French filed a motion in limine, on June 30, 2023, seeking to prohibit reference to or introduction of the informed consent form.",
      "paragraph_ref": "29",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "WRIT GRANTED; JUDGMENT REVERSED",
      "paragraph_ref": "7",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "We find that the probative value of evidence that Dr. French consented to the procedure, and was therefore informed of the risk, outweighs any potential prejudice.",
      "paragraph_ref": "81",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "Thus, there exists no rational basis for the exclusion of the evidence and its exclusion was an abuse of discretion by the trial court.",
      "paragraph_ref": "83",
      "speaker": "Judge's conclusion"
    }
  ],
