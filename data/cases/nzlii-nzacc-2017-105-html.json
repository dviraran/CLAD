  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Her injuries were caused by a treatment that she received, namely the hysterectomy carried out on 27 February 2014.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "EXPERT_TESTIMONY",
      "text": "Ms Newman submitted that the hysterectomy '[precipitated] a rise in intracranial pressure which in turn caused a feedback loop where the raised intracranial pressure coupled with seizures resulted in her severe brain injury'",
      "paragraph_ref": "17",
      "speaker": "Ms Newman"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "A significant period had elapsed before a CT scan was performed on Ms Brown, which resulted in the timeframe for intervention becoming more compressed.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Anticonvulsant therapy could have been administered earlier.",
      "paragraph_ref": "20",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Mr Law could have been called earlier; and, finally, Emergency surgery could have been performed earlier.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "Anticonvulsants could and should have been provided earlier;",
      "paragraph_ref": "26",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "A CT scan should have been performed earlier than 3pm on 4 March 2014;",
      "paragraph_ref": "27",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The on-call consultant neurosurgeon, Mr Law, should have been called earlier; and as a result",
      "paragraph_ref": "28",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The emergency surgery to remove the meningioma should have been performed earlier.",
      "paragraph_ref": "29",
      "speaker": "Judge's conclusion"
    }
  ],
