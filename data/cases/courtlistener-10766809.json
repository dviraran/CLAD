  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Defendant, Navarri Henderson, was charged by grand jury indictment with committing first degree rape of a female victim, J.F.",
      "paragraph_ref": "17",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "J.F. told Ms. Hamilton that she had been running on the levee when she was attacked by a man who had been sitting on a bench.",
      "paragraph_ref": "77",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "J.F. suffered a broken nose, arm, and hip, and was left to suffer, unable to pull herself up the levee, in the dark and cold and scream for help.",
      "paragraph_ref": "641",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "We affirm Defendant\u2019s convictions. We affirm Defendant\u2019s sentences for his first degree rape and aggravated kidnapping convictions.",
      "paragraph_ref": "648",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "J.F. told Ms. Hamilton that she bit the attacker\u2019s penis and that he retaliated by beating her.",
      "paragraph_ref": "80",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "J.F. testified that as she ran on the levee, she noticed 'the shape of a person on a bench\u2026who looked like they were just sitting there staring out at the river.'",
      "paragraph_ref": "100",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Officer Marian Mickey testified that at about 9:00 p.m. on December 28, 2016, she responded to a call for service involving a rape in the 700 block of Patterson Drive in Algiers.",
      "paragraph_ref": "54",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Ms. Acosta testified that J.F.\u2019s pelvis was 'papoosed' and her right arm was splinted.",
      "paragraph_ref": "88",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "J.F. reported that the assailant forced his penis into her mouth and that she bit his penis.",
      "paragraph_ref": "92",
      "speaker": "Witness statement"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "The record in this case does not reflect that the trial court abused its broad discretion when it sentenced Defendant to the mandatory life sentences for first degree rape and aggravated kidnapping.",
      "paragraph_ref": "645",
      "speaker": "Judge's conclusion"
    }
  ],
