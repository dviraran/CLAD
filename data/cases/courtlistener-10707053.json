  "summary": {
    "brief": "Jolene Luczak v. St. Mary's Medical Center. Medical malpractice case involving paediatrics.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In May 2019, appellant Jolene Luczak sought medical care for right calf pain.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Christopher Bunch diagnosed her with claudication (muscle pain from reduced blood flow) due to popliteal artery entrapment syndrome (PAES).",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Bunch referred Luczak to vascular surgeon Dr. Christopher DeMaioribus at respondent The Duluth Clinic Ltd.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Luczak expressed interest in a bypass, and surgery was scheduled for August 26 at respondent St. Mary\u2019s Medical.",
      "paragraph_ref": "30",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "During the surgery, Dr. DeMaioribus elected to perform a decompression.",
      "paragraph_ref": "34",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Luczak returned to work in late September, but by November her right-calf pain returned.",
      "paragraph_ref": "40",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "The MRA showed abnormal narrowing within the right popliteal artery.",
      "paragraph_ref": "42",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Dr. DeMaioribus recommended an angiogram and nonsurgical treatment.",
      "paragraph_ref": "46",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "He then placed a stent in the popliteal artery, and an angiogram showed what appeared to Dr. DeMaioribus to be normal blood flow.",
      "paragraph_ref": "50",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Luczak underwent a duplex ultrasound to screen for a pseudoaneurysm, which occurs when blood leaking from an injured blood vessel collects in surrounding tissue.",
      "paragraph_ref": "53",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E011",
      "type": "FACTUAL_FINDING",
      "text": "Luczak left for Colombia on February 21. While there, her groin pain returned, and she sought emergency medical care.",
      "paragraph_ref": "67",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E012",
      "type": "FACTUAL_FINDING",
      "text": "She was treated with antibiotics for infected hematomas, underwent surgery to repair a pseudoaneurysm in her left groin, and underwent a separate surgery to repair a rupture in her left iliac artery.",
      "paragraph_ref": "69",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E013",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Resnick\u2019s CV indicates that he has more than 20 years\u2019 experience working as an interventional radiologist and teaching in radiology and vascular surgery departments.",
      "paragraph_ref": "82",
      "speaker": "Dr. Resnick's CV"
    },
    {
      "evidence_id": "E014",
      "type": "EXPERT_TESTIMONY",
      "text": "He asserts that Dr. DeMaioribus breached the standard of care in the following ways: During the August 26, 2019 surgery, he failed to use plantar flexion maneuvers in connection with the intraoperative angiogram.",
      "paragraph_ref": "89",
      "speaker": "Dr. Resnick"
    },
    {
      "evidence_id": "E015",
      "type": "LEGAL_FINDING",
      "text": "The district court granted summary judgment in favor of the clinics.",
      "paragraph_ref": "123",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E016",
      "type": "COURT_REASONING",
      "text": "Luczak failed to demonstrate that he has the requisite practical experience.",
      "paragraph_ref": "178",
      "speaker": "Judge's analysis"
    }
  ],
