  "summary": {
    "brief": "Jesus Virlar, M.D. and GMG Health Systems Associates, P.A., A/K/A and D/B/A Gonzaba Medical Group v. Jo Ann Puente. Medical malpractice case involving paediatrics.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On November 28, 2011, Appellee Jo Ann Puente underwent 'Roux-en-Y' gastric bypass surgery, which was performed by Dr. Nilesh Patel.",
      "paragraph_ref": "40",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On January 16, 2012, Appellant Dr. Jesus Virlar, also a hospitalist and Gonzaba employee, assumed Puente\u2019s care and treated her until she was discharged on January 26, 2012.",
      "paragraph_ref": "61",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Altman testified thiamine deficiency caused Puente to develop 'changes in her mental state, causing confusion [and] behavioral changes.'",
      "paragraph_ref": "7",
      "speaker": "Dr. David Joseph Altman"
    },
    {
      "evidence_id": "E004",
      "type": "MEDICAL_RECORD",
      "text": "Puente\u2019s medical records reflect that she was awake, alert, and able to follow commands. She did not have any 'deficit of movement' to her upper or lower extremities.",
      "paragraph_ref": "53",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The jury returned a verdict in favor of Puente; it found that Dr. Patel was 40% responsible;",
      "paragraph_ref": "176",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "We affirm the judgment in part conditioned on a remittitur of damages in the amount of $8,000.00.",
      "paragraph_ref": "1382",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Altman testified symptoms of Wernicke\u2019s encephalopathy include 'ataxia, or problems with coordination; confusion, which is also called encephalopathy; and eye movement abnormalities.'",
      "paragraph_ref": "7",
      "speaker": "Dr. David Joseph Altman"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "On January 21, 2012, Puente\u2019s surgeon, Dr. Patel, wrote in her medical records to 'start TPN'; however, Puente was not started on TPN that day.",
      "paragraph_ref": "92",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "We reverse the judgment in part and remand the cause for the trial court (1) to conduct an evidentiary hearing on any benefit received by Puente from C.P.\u2019s settlement with the hospital.",
      "paragraph_ref": "1391",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "Puente was put on a trial of clear fluids, but was not able to tolerate the fluids by mouth.",
      "paragraph_ref": "90",
      "speaker": "Court finding"
    }
  ],
