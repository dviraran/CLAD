  "summary": {
    "brief": "FLORETTA FRANKLIN, as mother and next of kin to LATOYA PERRY v. OU MEDICINE. Medical malpractice case involving paediatrics.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Perry presented for treatment at OU Medical Center. According to the Petition, Bergdall was cleaning Perry when 'Bergdall dislodged the tracheotomy [sic] to the point that it fell out.'",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Due to the length of time the tracheotomy [sic] was out, [Perry] suffered an anoxic brain injury and coded.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "LEGAL_FINDING",
      "text": "The trial court's judgment affirmed. Since the PREP Act confers both immunity from liability and immunity from suit, Oklahoma courts lack subject matter jurisdiction to adjudicate the claims in Plaintiff's petition.",
      "paragraph_ref": "16",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Perry was admitted to OU Medical Center with severe 'SARS cov2 infection' and 'COVID pneumonia' on September 4, 2021.",
      "paragraph_ref": "20",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "On September 5, 2021, an ENT exchanged Perry's uncuffed tracheostomy for a cuffed tracheostomy secondary to the anticipated need for mechanical ventilation.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Perry 'was unable to be bagged initially due to pediatric sized trach getting dislodged and no [sic] allowing for a secure airway.'",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The PREP Act provides a 'covered person' with immunity from federal and state tort claims if the United States Secretary of Health and Human Services has declared a public health emergency.",
      "paragraph_ref": "175",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The trial court granted Defendants' motion to dismiss, finding PREP Act immunity applied because (1) Defendants were covered persons, (2) the cuffed tracheostomy tube was a covered countermeasure, and (3) Perry's injuries were related to the dislodgement of the cuffed tracheostomy tube.",
      "paragraph_ref": "176",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "We conclude that the cuffed tracheostomy provided to Perry is a 'covered countermeasure' pursuant to the PREP Act.",
      "paragraph_ref": "43",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E010",
      "type": "COURT_REASONING",
      "text": "Defendants conduct falls within the scope of administering a covered countermeasure.",
      "paragraph_ref": "53",
      "speaker": "Judge's analysis"
    }
  ],
