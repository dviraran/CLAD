      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On April 2, 2013, a multi-vehicle accident occurred on Interstate 10 in Jackson County.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "As a result of the car accident, Marcus suffered a cervical fracture and multiple rib fractures.",
      "paragraph_ref": "18",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Upon his release, Marcus was prescribed Lortab, a pain medication that contains hydrocodone and acetaminophen.",
      "paragraph_ref": "20",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "On April 8, 2013, emergency medical services (EMS) responded to the Smith home after Leslie called 911 due to Marcus\u2019s impaired mental condition and combativeness.",
      "paragraph_ref": "25",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Marcus ultimately died on September 24, 2013, from liver failure as a result of acetaminophen ingestion.",
      "paragraph_ref": "30",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Julie attached Federal Drug Administration regulations to his sworn affidavit, which explained that liver failure resulting from pain medication has been known and addressed by the government for a very long time.",
      "paragraph_ref": "57",
      "speaker": "Dr. Julie"
    },
    {
      "evidence_id": "E007",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Kesterson testified that in his thirty years of medical experience, he had never known a patient to die from liver failure as a result of the ingestion of pain medication.",
      "paragraph_ref": "56",
      "speaker": "Dr. Kesterson"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The judgment of the Court of Appeals is affirmed. The judgment of the Jackson County Circuit Court is reversed and remanded.",
      "paragraph_ref": "199",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "Foreseeability comes into play in two of the four elements of negligence. As part of the causation element, whether a consequence of an alleged negligent act or omission is foreseeable is a question of fact.",
      "paragraph_ref": "202",
      "speaker": "Court reasoning"
    }
  ],
