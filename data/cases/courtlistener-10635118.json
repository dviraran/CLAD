  "summary": {
    "brief": "Paulsen v. Avera McKennan. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Jessica Paulsen had severe bleeding after giving birth. On December 14, 2021, Dr. Amber Saloum and the staff at the Avera McKennan Hospital performed a hysterectomy and another surgery to stop Paulsen\u2019s bleeding.",
      "paragraph_ref": "11",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Paulsen insists that she did not consent to a possible hysterectomy.",
      "paragraph_ref": "31",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "In the early morning hours of December 14, 2021, Dr. Saloum began an exploratory laparotomy and quickly determined the uterus had ruptured and that uterine tears were present in two different locations.",
      "paragraph_ref": "34",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Paulsen continued to bleed after the hysterectomy was completed and underwent a second surgery in the early morning hours of December 14, 2021, to explore a suspected intraabdominal hemorrhage.",
      "paragraph_ref": "37",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The circuit court concluded the statute of repose barred Paulsen\u2019s suit.",
      "paragraph_ref": "82",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "Because Paulsen commenced her lawsuit on December 15, 2023, one day too late, the statute of repose in SDCL 15-2-14.1 bars her claim. We affirm.",
      "paragraph_ref": "258",
      "speaker": "Judge's conclusion"
    }
  ],
