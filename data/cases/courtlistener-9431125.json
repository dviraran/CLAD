    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Bandaru, at the age of 37, was admitted to OSUWMC on January 10, 2018 for chemotherapy treatment for Acute Lymphoblastic Leukemia (ALL).",
      "paragraph_ref": "3",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The permanence of Bandaru’s disabilities prevented him from testifying himself.",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "MEDICAL_RECORD",
      "text": "Bandaru did not have any focal deficits, his pupils were equally round and reactive to light, and no signs or symptoms of stroke were noted.",
      "paragraph_ref": "11",
      "speaker": "Medical record"
    },
    {
      "evidence_id": "E004",
      "type": "WITNESS_STATEMENT",
      "text": "While she was on her errand, she testified that Bandaru called her to ask her when she would be back. She said that he explained that he was very weak.",
      "paragraph_ref": "8",
      "speaker": "Kumchala"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "There is a consensus among healthcare providers that PEG-asparaginase increases a patient’s risk of developing a blood clot.",
      "paragraph_ref": "4",
      "speaker": "Expert testimony"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The Court enters judgment in favor of Defendant.",
      "paragraph_ref": "2",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "The main reason for this finding is that there was a verified report of only one possible stroke symptom at that time: numbness and tingling diffusely.",
      "paragraph_ref": "34",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "At 12:25 p.m., Bandaru was given assistance when he was repositioned in his bed.",
      "paragraph_ref": "20",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "MEDICAL_RECORD",
      "text": "Pt c/o numbness and tingling throughout entire body. Continues to c/o of dizziness with activity.",
      "paragraph_ref": "21",
      "speaker": "Medical record"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "The negligence of Defendant was not the proximate cause of this terrible ending.",
      "paragraph_ref": "73",
      "speaker": "Judge's conclusion"
    }
  ],
