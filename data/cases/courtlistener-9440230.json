  "summary": {
    "brief": "Estate of Cindy Essex v. Grant County Pub. Hosp. Dist. No. 1. Medical malpractice case involving paediatrics.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On June 24, 2015, Cindy Essex visited Samaritan Healthcare\u2019s emergency department in Moses Lake complaining of left shoulder pain.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "She was experiencing 10 out of 10 pain and abdominal cramping. She arrived at 2:13 p.m. and was triaged at 2:31 p.m.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Christopher Davis arrived at 3:47 p.m. to assess Ms. Essex. She reported bloody diarrhea, vomiting, general abdominal pain.",
      "paragraph_ref": "21",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Davis ordered two milligrams of intramuscular hydromorphone for pain, which was administered to Ms. Essex at 3:56 p.m.",
      "paragraph_ref": "29",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "The x-rays, as read by radiologist Dr. Irene Cruite at 5:19 p.m., showed a '[n]onspecific paucity of gas in the bowel loops with a large gastric air bubble.'",
      "paragraph_ref": "34",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Davis suspected Ms. Essex had a gastric outlet obstruction and ordered a computed tomography (CT) scan of her abdomen and pelvis.",
      "paragraph_ref": "37",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "The report of her CT scan was completed at 6:20 p.m. As interpreted by Dr. Cruite, it showed a '[m]arkedly distended stomach with[ ] fluid, suspicious for gastric outlet obstruction.'",
      "paragraph_ref": "40",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "At 6:56 p.m., a nasogastric tube was inserted into Ms. Essex\u2019s stomach and 1.6 to 1.8 liters of clear green fluid was removed.",
      "paragraph_ref": "46",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Davis consulted with a gastroenterologist, who recommended Ms. Essex be transferred for endoscopy.",
      "paragraph_ref": "49",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "At 8:25 p.m., while waiting for transfer, Ms. Essex reported that her lower back pain was again a 10 out of 10.",
      "paragraph_ref": "64",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E011",
      "type": "FACTUAL_FINDING",
      "text": "Ms. Essex arrived at Central Washington Hospital at 10:10 p.m. She was very lethargic and had a high heart rate and low blood pressure.",
      "paragraph_ref": "69",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E012",
      "type": "FACTUAL_FINDING",
      "text": "A CT scan at 1:11 a.m. revealed '[e]xtensive contusion or edema in the body wall . . . on the left.'",
      "paragraph_ref": "75",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E013",
      "type": "FACTUAL_FINDING",
      "text": "The surgery revealed extensive areas of nonviable muscle, beyond anything the surgeon had seen.",
      "paragraph_ref": "84",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E014",
      "type": "LEGAL_FINDING",
      "text": "We conclude the trial court erred in dismissing Essex\u2019s negligence claim against Samaritan\u2019s nurses.",
      "paragraph_ref": "484",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E015",
      "type": "LEGAL_FINDING",
      "text": "Affirmed in part, reversed in part.",
      "paragraph_ref": "488",
      "speaker": "Judge's conclusion"
    }
  ],
