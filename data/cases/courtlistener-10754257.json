  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "When Kirsten found Kevin unresponsive one morning, she first called Tina and then called 9-1-1 for assistance.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Kevin was deceased, and described his condition as 'very malnourished[,] skin and bones[,] and very underweight and emaciated.'",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Tina was charged with injury to a child for failing to provide Kevin with adequate food and medical care.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "WITNESS_STATEMENT",
      "text": "White testified that Kevin could open the refrigerator and, unlike some Down Syndrome children, 'was a good eater.'",
      "paragraph_ref": "48",
      "speaker": "Colleen White"
    },
    {
      "evidence_id": "E005",
      "type": "WITNESS_STATEMENT",
      "text": "Kirsten testified that Tina visited them sometimes, 'but she would mostly stay in Houston with her boyfriend.'",
      "paragraph_ref": "63",
      "speaker": "Kirsten"
    },
    {
      "evidence_id": "E006",
      "type": "WITNESS_STATEMENT",
      "text": "Kirsten testified that it was Jaylin who put Kevin in the closet.",
      "paragraph_ref": "75",
      "speaker": "Kirsten"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We affirm the trial court\u2019s judgments in trial court cause numbers F22-40200 and F22-40201.",
      "paragraph_ref": "574",
      "speaker": "Judge's conclusion"
    }
  ],
