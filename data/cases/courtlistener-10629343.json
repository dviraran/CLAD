    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "The circuit court\u2019s primary reason for dismissing Foote\u2019s claim against the Hospital was the lack of expert testimony on causation.",
      "paragraph_ref": "337",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Foote\u2019s blood pressure dropped at 9:03 a.m., and nurse anesthetist Meghan Fisackerly told Burwell she was having a problem with Foote\u2019s blood pressure.",
      "paragraph_ref": "37",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Graham was notified of the request around 9:51 a.m. He advised that he was unavailable.",
      "paragraph_ref": "42",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Graham came to the PACU, and diagnosed Foote with a large retroperitoneal hematoma.",
      "paragraph_ref": "61",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "The jury found proximate cause and returned a verdict against Dr. Graham and the Hospital.",
