    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Graham suspected a potential retroperitoneal hematoma but determined that Foot was stable.",
      "paragraph_ref": "48",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Banks. He said there was a deviation from the standard of care.",
      "paragraph_ref": "206",
      "speaker": "Expert testimony"
