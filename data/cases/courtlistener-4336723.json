    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Complications arose during Braylon's delivery. Almost immediately after Braylon's head appeared, the head retracted, indicating a shoulder dystocia.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Braylon's shoulder was injured, however, and the growth and function of Braylon's left arm are permanently and severely limited.",
      "paragraph_ref": "32",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Braylon's obstetrical expert witness, Dr. Jeffrey Wener, testified that he was familiar with the standard of care for family practitioners practicing obstetrics.",
      "paragraph_ref": "38",
      "speaker": "Dr. Jeffrey Wener"
    },
    {
      "evidence_id": "E004",
      "type": "LEGAL_FINDING",
      "text": "The jury's special verdict found that the defendant doctor was negligent in the delivery of Braylon and in the prenatal care of his mother and that this negligence was a cause of injury to Braylon.",
      "paragraph_ref": "65",
      "speaker": "Jury verdict"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The jury did not award any damages to Braylon's parents.",
      "paragraph_ref": "73",
      "speaker": "Jury verdict"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The circuit court ruled in favor of admitting Dr. Wener's testimony at each of these junctures.",
      "paragraph_ref": "87",
      "speaker": "Circuit court"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "We conclude that Dr. Wener's testimony was reliable and admissible under \u00a7 907.02(1).",
      "paragraph_ref": "125",
      "speaker": "Supreme Court of Wisconsin"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The circuit court did not err in applying Wis. Stat. \u00a7 907.02(1) and admitting as reliable Dr. Wener's expert medical testimony.",
      "paragraph_ref": "105",
      "speaker": "Supreme Court of Wisconsin"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Braylon claims that the defendant doctor's care during delivery fell below the standard of reasonable care and caused him to have a permanent brachial plexus injury.",
      "paragraph_ref": "34",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Wener explained the reasonable care to be used in a case like the instant one and opined that the care provided and the procedures used by the defendant doctor fell below the standard of reasonable care.",
      "paragraph_ref": "41",
      "speaker": "Dr. Jeffrey Wener"
    }
  ],
