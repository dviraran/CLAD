  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Joao Barbosa, et ux. v. Tanisha Osbourne, No. 1258, September Term, 2015, filed: April 26, 2018",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa, after experiencing 'severe' and persistent abdominal pain throughout the day, went to the emergency room of the Frederick Memorial Hospital.",
      "paragraph_ref": "39",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa left the hospital, as he had waited for over two hours to be seen by a doctor, without success, and his pain had diminished.",
      "paragraph_ref": "45",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa continued to experience abdominal pain, and, that evening, he had trouble eating and sleeping.",
      "paragraph_ref": "50",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa returned to the emergency room eleven days after having left it, complaining that his abdominal pain had worsened.",
      "paragraph_ref": "57",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Osbourne examined Mr. Barbosa and confirmed the preliminary results of the ultrasound scan, namely, that he was suffering from inflammation of the gallbladder.",
      "paragraph_ref": "64",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa consented to the proposed surgery and cholangiography.",
      "paragraph_ref": "70",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Osbourne observed a small amount of bile, which, in her words, was 'where it shouldn\u2019t be.'",
      "paragraph_ref": "82",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Barbosa was transferred to the University of Maryland Medical Center, where an ERCP was successfully performed, confirming damage to the bile duct.",
      "paragraph_ref": "88",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "JUDGMENT OF THE CIRCUIT COURT FOR FREDERICK COUNTY REVERSED. CASE REMANDED TO THAT COURT FOR FURTHER PROCEEDINGS NOT INCONSISTENT WITH THIS OPINION.",
      "paragraph_ref": "475",
      "speaker": "Judge's conclusion"
    }
  ],
