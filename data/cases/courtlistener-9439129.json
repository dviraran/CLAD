  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In March, 2020, shortly after the onset of the COVID-19 pandemic, C went to the emergency room at a hospital in Norwich complaining of a sore throat and a headache.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The emergency room staff suspected that C was experiencing a myocardial infarction.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "C was transferred to Hartford Hospital, where such facilities are available.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "R was concerned that C could have COVID-19 and doubted that she was suffering from a myocardial infarction.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "A COVID-19 diagnostic test was administered on March 21, 2020.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "FACTUAL_FINDING",
      "text": "On March 24, 2020, C’s test result came back as negative.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "FACTUAL_FINDING",
      "text": "On March 25, 2020, F ordered that C undergo a coronary angiogram in the hospital’s catheterization lab, but C died of a myocardial infarction before the procedure was administered.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "The trial court ultimately granted the motions to dismiss with respect to the claims directed at the defendant physicians’ acts or omissions that occurred before the receipt of C’s negative COVID-19 test result on March 24, 2020, but denied one of the motions to dismiss with respect to claims directed at acts or omissions occurring after that time.",
      "paragraph_ref": "4",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "COURT_REASONING",
      "text": "The trial court correctly determined that, under Executive Order No. 7V, the defendants were immune for any negligent acts or omissions occurring before, but not after, the receipt of C’s negative COVID-19 test result.",
      "paragraph_ref": "1",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E010",
      "type": "LEGAL_FINDING",
      "text": "The trial court incorrectly concluded that, under the federal PREP Act, the defendants were immune from suit and liability for their allegedly negligent and grossly negligent acts or omissions occurring before the receipt of C’s negative COVID-19 test result.",
      "paragraph_ref": "2",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E011",
      "type": "COURT_REASONING",
      "text": "The immunity conferred by the PREP Act is different from—and much narrower than—that conferred by Executive Order No. 7V and does not cover the claims presently under consideration.",
      "paragraph_ref": "II",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E012",
      "type": "COURT_REASONING",
      "text": "The receipt of C’s negative test result broke any meaningful connection between F’s treatment of C and his provision of health care services in support of the state’s COVID-19 response.",
      "paragraph_ref": "16",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E013",
      "type": "LEGAL_FINDING",
      "text": "Accordingly, the plaintiff was entitled to proceed on the counts of her complaint alleging gross negligence as to all of the defendants and the counts of her complaint alleging negligence as to F and H Co.",
      "paragraph_ref": "31",
      "speaker": "Court finding"
    }
  ],
