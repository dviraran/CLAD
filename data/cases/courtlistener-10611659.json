  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Johnson was diagnosed with diabetes in 1996.",
      "paragraph_ref": "19",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "In April 2003, he sought treatment within the Ochsner Health System for 'blistering' on his left foot and saw Dr. Coleman.",
      "paragraph_ref": "20",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Coleman referred Mr. Johnson to a surgeon, Dr. Farrell Johnson, who successfully treated the wound with antibiotics, topical medication, dry wraps, and glucose monitoring.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Mr. Johnson ultimately required a partial amputation below the knee of his left leg.",
      "paragraph_ref": "28",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "On June 19, 2006, one week later, removal of the Unna boot revealed the development of a three-centimeter ulcer.",
      "paragraph_ref": "49",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "EXPERT_TESTIMONY",
      "text": "Vagnoni planned to testify that Dr. Coleman\u2019s application of the Unna boot caused the ulcer.",
      "paragraph_ref": "134",
      "speaker": "Expert witness"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "The trial court abused its discretion in determining that Ms. Vagnoni was qualified to provide expert testimony outside of her expertise.",
      "paragraph_ref": "237",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "We grant the writ in part and reverse the portion of the trial court\u2019s April 19, 2022 judgment that denied Relators\u2019 Motion to Exclude Ms. Vagnoni as an expert witness.",
      "paragraph_ref": "239",
      "speaker": "Judge's analysis"
    }
  ],
