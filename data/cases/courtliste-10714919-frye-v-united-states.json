    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Frye\u2019s allegations center on a surgical procedure that he underwent for a nasal fracture in October 2022, at Midlands Hospital in Columbia, South Carolina.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "He claims that during the procedure, a 'Neurological Telemetry System' was implanted into his brain.",
      "paragraph_ref": "26",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Frye claims that between October 2022 and March 2023, he did not receive a requested MRI following pain in his urinary tract.",
      "paragraph_ref": "38",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "In March 2023, he claims that officials at the Evans Correctional Institution in Bennettsville, South Carolina, '[h]azed and tormented' him.",
      "paragraph_ref": "39",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "The Court will, accordingly, dismiss both cases sua sponte for improper venue.",
      "paragraph_ref": "155",
      "speaker": "Judge's conclusion"
    }
