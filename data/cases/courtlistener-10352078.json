    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Marlene has a long history of back pain. She had spinal surgery in 1985, and two more surgeries about five years later.",
      "paragraph_ref": "56",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "On July 24, Dr. Beck performed a lumbar laminectomy on Marlene at Mercy Medical Center\u2013North Iowa.",
      "paragraph_ref": "59",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "On August 14, Marlene was seen in the local emergency room complaining of double vision, glossy eyes, and chronic back pain.",
      "paragraph_ref": "66",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "The next day, an MRI revealed an epidural hematoma, a complication from her July 24 laminectomy.",
      "paragraph_ref": "68",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Beck performed emergency surgery that day to evacuate the epidural hematoma.",
      "paragraph_ref": "69",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The plaintiffs appeal from the district court\u2019s ruling dismissing their medical malpractice action as time-barred.",
      "paragraph_ref": "10",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We apply our cases interpreting section 147.140 to hold that the certificates in this case did not substantially comply with the statute\u2019s affidavit requirement.",
      "paragraph_ref": "45",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E008",
      "type": "LEGAL_FINDING",
      "text": "We reject the plaintiffs\u2019 claim that section 147.140 is void for vagueness.",
      "paragraph_ref": "49",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "We remand the case for an order granting the defendants\u2019 motions for summary judgment.",
      "paragraph_ref": "52",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E010",
      "type": "FACTUAL_FINDING",
      "text": "The Banwarts alleged Dr. Beck breached the standard of care in his July 24, 2018 surgery and postoperative care.",
      "paragraph_ref": "76",
      "speaker": "Court finding"
    }
  ],
