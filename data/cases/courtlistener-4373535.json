  "summary": {
    "brief": "Estrada v. Univ. of Toledo Med. Ctr.. Medical malpractice case involving obstetrics gynaecology.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Geisler testified that he first saw Mrs. Becerra on September 9, 2010. Dr. Geisler testified that Mrs. Becerra, who was 62 years old at the time, was referred to him based upon concerns about intermittent post-menopausal bleeding over the prior two years.",
      "paragraph_ref": "6",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "The surgery was performed on September 20, 2010, Dr. Geisler stated, and assisting him were resident physicians Drs. Kathleen Rinkes and Megan Lutz.",
      "paragraph_ref": "7",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Geisler testified that during the operation a coagulant was administered because a significant amount of bleeding occurred, especially from the back of the vaginal cuff, and it was the kind of diffuse 'oozing' that is seen in patients with cirrhosis of the liver.",
      "paragraph_ref": "7",
      "speaker": "Dr. Geisler"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Dr. Geisler stated that he did not see Mrs. Becerra on the third day after the operation, on September 23, 2010, but that Dr. Manahan did, and the records show that a CT scan was performed that day which was interpreted by the radiologist as depicting a large ventral hernia.",
      "paragraph_ref": "9",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Manahan testified that Mrs. Becerra’s condition on September 23, 2010, did not constitute a surgical emergency.",
      "paragraph_ref": "13",
      "speaker": "Dr. Manahan"
    },
    {
      "evidence_id": "E006",
      "type": "WITNESS_STATEMENT",
      "text": "Estrada testified that she came to the hospital to visit on the day of the surgery, and the next day as well, and nothing seemed out of the ordinary to her.",
      "paragraph_ref": "14",
      "speaker": "Rosa Estrada"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "Based on the foregoing, the magistrate finds that plaintiff did not prove her claim by a preponderance of the evidence. Accordingly, judgment is recommended in favor of defendant.",
      "paragraph_ref": "75",
      "speaker": "Judge's conclusion"
    }
  ],
