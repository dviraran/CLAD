  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On October 6, 2022, three-year-old D.H. sustained head injuries while in the care of Kitto, the live-in boyfriend of D.H.\u2019s mother, Kelly.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Kitto called 911 and texted Kelly to report an accident. D.H. was not breathing when paramedics arrived.",
      "paragraph_ref": "16",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "D.H. was transported to the emergency room, then life-flighted to the children\u2019s hospital and stabilized.",
      "paragraph_ref": "22",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "After doctors determined D.H. was brain dead, Kelly and D.H.\u2019s father made the decision to remove D.H. from life support.",
      "paragraph_ref": "24",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Randall Schlievert, a child abuse expert, was consulted to examine D.H. and provide an opinion regarding D.H.\u2019s injuries.",
      "paragraph_ref": "52",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "Accordingly, we find Kitto\u2019s seventh assignment of error well-taken.",
      "paragraph_ref": "1079",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "Finding substantial justice has not been done, we reverse the judgment of the Lucas County Court of Common Pleas, vacate the conviction, and remand the matter for a new trial.",
      "paragraph_ref": "1081",
      "speaker": "Judge's conclusion"
    }
  ],
