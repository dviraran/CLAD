  "summary": {
    "brief": "Orcutt v. Miller. Medical malpractice case involving surgery orthopaedic.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "In 1969 appellant, Terry Orcutt, consulted respondent, Dr. Miller, complaining of nausea, vomiting, diarrhea and dizziness.",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "Orcutt remained under Dr. Miller\u2019s care for a period of nineteen months, during which time he was admitted for treatment on three occasions to Sunrise Hospital in Las Vegas.",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "Appellant\u2019s condition progressively worsened, and, on July 8, 1971, the patient traveled by air ambulance to Santa Barbara, California where, immediately upon his arrival, the diagnosis of toxic megacolon was made, and within two hours thereafter, a colectomy performed.",
      "paragraph_ref": "1",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "EXPERT_TESTIMONY",
      "text": "Dr. Imperato stated that in his opinion appellant\u2019s condition 'may have been precipitated by (1) poor medical care and (2) the injudicious use of opiates during an acute flare up of the patient\u2019s colitis.'",
      "paragraph_ref": "1",
      "speaker": "Dr. Thomas J. Imperato"
    },
    {
      "evidence_id": "E005",
      "type": "LEGAL_FINDING",
      "text": "Accordingly, the court granted Dr. Miller\u2019s motion for summary judgment, finding specifically that appellant had failed to establish a breach of the accepted standard of care.",
      "paragraph_ref": "1",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E006",
      "type": "COURT_REASONING",
      "text": "The amended affidavit of appellant\u2019s expert, submitted on the date set for hearing of respondent\u2019s motion for summary judgment, contains persuasive allegations to the effect that Dr. Miller\u2019s treatment 'probably' precipitated appellant\u2019s ultimate condition.",
      "paragraph_ref": "3",
      "speaker": "Court analysis"
    },
    {
      "evidence_id": "E007",
      "type": "LEGAL_FINDING",
      "text": "We reverse the order of the district court granting respondent summary judgment.",
      "paragraph_ref": "2",
      "speaker": "Judge's conclusion"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "Board certified specialists should be held to national standards of the specialty.",
      "paragraph_ref": "2",
      "speaker": "Court analysis"
    },
    {
      "evidence_id": "E009",
      "type": "EXPERT_TESTIMONY",
      "text": "The expert\u2019s opinion that Dr. Miller\u2019s treatment of appellant departed from accepted standards of the specialty and 'probably' caused appellant\u2019s ultimate condition was sufficient to overcome respondent\u2019s motion for summary judgment.",
      "paragraph_ref": "13",
      "speaker": "Court analysis"
    }
  ],
