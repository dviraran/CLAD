  "case_name": "Paul & Anor v The Royal Wolverhampton NHS Trust [2020] EWHC 1415 (QB)",
  "neutral_citation": "[2020] EWHC 1415",
  "clinical_domain": "CARDIOLOGY",
  "outcome_severity": "DEATH",
  "summary": {
    "brief": "Patient presented with chest and jaw pain. Hospital failed to diagnose ischaemic heart disease and coronary artery atherosclerosis. Patient was discharged without coronary angiography and died from a heart attack 14 months later.",
    "clinical_synopsis": "Clinical case extracted from judgment.",
    "legal_synopsis": "Legal proceedings and judgment."
  },
  "evidence_index": [
    {
      "evidence_id": "E001",
      "type": "FACTUAL_FINDING",
      "text": "On 9 November 2012, Mr Paul was admitted to New Cross Hospital in Wolverhampton, part of the Defendant Trust, after complaining of chest and jaw pain.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E002",
      "type": "FACTUAL_FINDING",
      "text": "He was discharged on 12 November 2012 after various tests and investigations.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E003",
      "type": "FACTUAL_FINDING",
      "text": "More than 14 months later, on 26 January 2014, while out on a shopping trip with Saffron (then 12) and Mya (then 9), he collapsed and died from a heart attack.",
      "paragraph_ref": "13",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E004",
      "type": "FACTUAL_FINDING",
      "text": "Mr Paul's heart attack was caused by ischaemic heart disease and occlusive coronary artery atherosclerosis.",
      "paragraph_ref": "14",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E005",
      "type": "EXPERT_TESTIMONY",
      "text": "The Claimants' case is that the failure to diagnose these conditions during Mr Paul's stay in hospital in November 2012 was negligent.",
      "paragraph_ref": "14",
      "speaker": "Claimants' position"
    },
    {
      "evidence_id": "E006",
      "type": "LEGAL_FINDING",
      "text": "The Defendant accepts that it owed a duty of care to Mrs Paul. It does not accept that it owed a duty of care to Saffron or Mya.",
      "paragraph_ref": "15",
      "speaker": "Court finding"
    },
    {
      "evidence_id": "E007",
      "type": "COURT_REASONING",
      "text": "Foreseeability in this context involves 'a hypothetical person, looking with hindsight at an event which has occurred'.",
      "paragraph_ref": "108",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E008",
      "type": "COURT_REASONING",
      "text": "The control mechanisms limit liability for psychiatric injury which is proved to have been caused by the defendant's negligence.",
      "paragraph_ref": "108",
      "speaker": "Judge's analysis"
    },
    {
      "evidence_id": "E009",
      "type": "LEGAL_FINDING",
      "text": "The appeal will be allowed and the Master's order striking out the Claimants' claims will be set aside.",
      "paragraph_ref": "124",
      "speaker": "Judge's conclusion"
    }
  ],
